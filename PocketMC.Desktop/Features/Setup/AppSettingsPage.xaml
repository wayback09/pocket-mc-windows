<Page x:Class="PocketMC.Desktop.Features.Setup.AppSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Settings">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="VisibleIfTrue"/>
        <presentation:InverseBooleanToVisibilityConverter x:Key="InvertedVisibilityConverter" xmlns:presentation="clr-namespace:PocketMC.Desktop.Core.Presentation"/>
    </Page.Resources>

    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="App Settings"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                   Margin="24,24,24,16" />

        <ScrollViewer Grid.Row="1"
                      x:Name="MainScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,0,24,24">
            <StackPanel>
                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon Settings24}" Margin="0,0,0,12">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="App Behavior" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Control startup and tray behavior." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Start PocketMC with Windows" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Register PocketMC in your current Windows account startup apps."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleStartWithWindows"
                                             Grid.Column="1"
                                             VerticalAlignment="Center"
                                             Checked="ToggleStartWithWindows_Changed"
                                             Unchecked="ToggleStartWithWindows_Changed"/>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Start minimized to tray" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="When Windows starts PocketMC, keep the dashboard hidden and show the tray icon."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleStartMinimizedToTray"
                                             Grid.Column="1"
                                             VerticalAlignment="Center"
                                             Checked="ToggleStartMinimizedToTray_Changed"
                                             Unchecked="ToggleStartMinimizedToTray_Changed"/>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Minimize to tray on close" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Keep PocketMC running in the tray when the main window is closed."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleMinimizeToTrayOnClose"
                                             Grid.Column="1"
                                             VerticalAlignment="Center"
                                             Checked="ToggleMinimizeToTrayOnClose_Changed"
                                             Unchecked="ToggleMinimizeToTrayOnClose_Changed"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon Power24}" Margin="0,0,0,12">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Power Management" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Control how PocketMC keeps running servers available." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Keep this PC awake while servers are running" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Allows the screen to turn off, but prevents Windows from sleeping so servers and tunnels stay online."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleKeepComputerAwakeWhileServersRunning"
                                             Grid.Column="1"
                                             VerticalAlignment="Center"
                                             Checked="ToggleKeepComputerAwakeWhileServersRunning_Changed"
                                             Unchecked="ToggleKeepComputerAwakeWhileServersRunning_Changed"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <!-- UPDATES -->
                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon ArrowDownload24}" Margin="0,0,0,12">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Software Updates" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Manage and check for application updates." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16">
                        <TextBlock Text="Check for Updates" FontSize="14" FontWeight="Medium"/>
                        <TextBlock Text="Looking for a newer version of PocketMC Desktop? Click below to check manually." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,12" TextWrapping="Wrap"/>
                        <ui:Button x:Name="BtnCheckUpdates" Content="Check for Updates" Icon="{ui:SymbolIcon ArrowSync24}" Appearance="Secondary" Click="CheckUpdates_Click"/>
                        <TextBlock x:Name="UpdateStatusText" FontSize="12" Margin="0,8,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon Color24}" Margin="0,0,0,12">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Appearance" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Customize how the application looks." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16">
                        <!-- Backdrop Selection -->
                        <TextBlock Text="Window Background Theme" FontSize="14" FontWeight="Medium" Margin="0,0,0,0"/>
                        <TextBlock Text="Select your preferred window background effect." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,8" TextWrapping="Wrap"/>
                        <ComboBox x:Name="BackdropCombo" Width="260" HorizontalAlignment="Left" SelectionChanged="BackdropCombo_SelectionChanged">
                            <!-- Items populated dynamically based on OS version -->
                        </ComboBox>

                        <!-- Custom Background Image — only shown when Wallpaper Blur is selected -->
                        <StackPanel x:Name="CustomBackgroundPanel" Visibility="Collapsed" Margin="0,16,0,0">
                            <Separator Margin="0,0,0,12" Opacity="0.15"/>
                            <TextBlock Text="Custom Background Image" FontSize="14" FontWeight="Medium"/>
                            <TextBlock Text="Use a custom image instead of your desktop wallpaper. The image will be blurred and darkened automatically." 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,10" TextWrapping="Wrap"/>

                            <!-- Preview + Controls -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Thumbnail preview -->
                                <Border x:Name="CustomBgPreviewBorder"
                                        Width="80" Height="48"
                                        CornerRadius="6"
                                        BorderThickness="1"
                                        BorderBrush="#30FFFFFF"
                                        Background="#18FFFFFF"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Center">
                                    <Grid>
                                        <Image x:Name="CustomBgPreviewImage"
                                               Stretch="UniformToFill"
                                               Visibility="Collapsed"/>
                                        <ui:SymbolIcon x:Name="CustomBgPlaceholderIcon"
                                                       Symbol="Image24"
                                                       FontSize="20"
                                                       Foreground="#50FFFFFF"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Path + Buttons -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="CustomBgPathLabel"
                                               Text="No custom image selected"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:Button x:Name="BtnBrowseCustomBg"
                                                   Content="Browse Image"
                                                   Icon="{ui:SymbolIcon FolderOpen24}"
                                                   Appearance="Secondary"
                                                   Click="BrowseCustomBackground_Click"
                                                   Margin="0,0,8,0"/>
                                        <ui:Button x:Name="BtnClearCustomBg"
                                                   Content="Use Wallpaper"
                                                   Icon="{ui:SymbolIcon Dismiss24}"
                                                   Appearance="Danger"
                                                   Click="ClearCustomBackground_Click"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon Alert24}" Margin="0,0,0,12">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Notifications" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Manage desktop notifications." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Server Online Notification" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Show a notification when a server finishes starting up and becomes online."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleServerOnlineNotifications"
                                             Grid.Column="1"
                                             VerticalAlignment="Center"
                                             Checked="ToggleServerOnlineNotifications_Changed"
                                             Unchecked="ToggleServerOnlineNotifications_Changed"/>
                        </Grid>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Agent Connect Notification" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Show a notification when the Playit agent successfully connects."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleAgentConnectNotifications"
                                             Grid.Column="1"
                                             VerticalAlignment="Center"
                                             Checked="ToggleAgentConnectNotifications_Changed"
                                             Unchecked="ToggleAgentConnectNotifications_Changed"/>
                        </Grid>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Remote Control Online Notification" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Show a notification when the remote control service is online and a tunnel is found."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleRemoteControlNotifications"
                                             Grid.Column="1"
                                             VerticalAlignment="Center"
                                             Checked="ToggleRemoteControlNotifications_Changed"
                                             Unchecked="ToggleRemoteControlNotifications_Changed"/>
                        </Grid>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="AI Summary Notification" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Show a notification when AI session summarization starts and completes."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleAiSummaryNotifications"
                                             Grid.Column="1"
                                             VerticalAlignment="Center"
                                             Checked="ToggleAiSummaryNotifications_Changed"
                                             Unchecked="ToggleAiSummaryNotifications_Changed"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon People24}" Margin="0,0,0,12">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Discord Integration" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Show your active server status on your Discord profile." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Discord Rich Presence" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Display your server type, player count, uptime, and a Join button directly on your Discord profile while a server is running." 
                                           TextWrapping="Wrap" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                           FontSize="12" 
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleDiscordRpc" Grid.Column="1" VerticalAlignment="Center" 
                                             Checked="ToggleDiscordRpc_Changed" 
                                             Unchecked="ToggleDiscordRpc_Changed"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon Cloud24}" Margin="0,0,0,12">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Cloud Backups" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Native cloud backup integration for disaster recovery." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16" DataContext="{Binding CloudBackups, RelativeSource={RelativeSource AncestorType=Page}}">
                        <!-- Toggles -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Enable Cloud Backups" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Master toggle to allow instances to upload backups to configured providers." TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding EnableCloudBackups, Mode=TwoWay}"/>
                        </Grid>

                        <Separator Margin="0,16" Opacity="0.15"/>

                        <ItemsControl ItemsSource="{Binding ProviderViewModels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Symbol="Cloud24" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="24"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ProviderType}" FontSize="14" FontWeight="Medium"/>
                                            <TextBlock Text="{Binding AccountInfo}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" Margin="0,0,12,0" Visibility="{Binding IsBusy, Converter={StaticResource VisibleIfTrue}}"/>
                                            <ui:Button Content="Connect" Command="{Binding ConnectCommand}" Appearance="Primary" Margin="0,0,8,0" Visibility="{Binding IsConnected, Converter={StaticResource InvertedVisibilityConverter}}" />
                                            <ui:Button Content="Disconnect" Command="{Binding DisconnectCommand}" Appearance="Danger" Visibility="{Binding IsConnected, Converter={StaticResource VisibleIfTrue}}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon Key24}" Margin="0,0,0,12">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="API Configuration" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Configure third-party API keys for services like CurseForge." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="CurseForge API Key" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Obtain a key from CurseForge console if you hit rate limits." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <ui:TextBox x:Name="CurseForgeKeyInput" Margin="0,8,0,0" PlaceholderText="$2a$10$..."/>
                            </StackPanel>
                            <ui:Button Grid.Column="1" Content="Save Key" Appearance="Primary" VerticalAlignment="Bottom" Click="SaveApiKey_Click"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon BrainCircuit24}" Margin="0,0,0,12">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="AI Session Summarization" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Generate AI-powered summaries of your server sessions when they stop." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16">
                        <!-- Provider Selection -->
                        <TextBlock Text="AI Provider" FontSize="14" FontWeight="Medium"/>
                        <TextBlock Text="Select the AI service you have an API key for." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,8" TextWrapping="Wrap"/>
                        <ComboBox x:Name="AiProviderCombo" Width="260" HorizontalAlignment="Left" SelectionChanged="AiProviderCombo_SelectionChanged">
                            <ComboBoxItem Content="Google Gemini" IsSelected="True"/>
                            <ComboBoxItem Content="OpenAI"/>
                            <ComboBoxItem Content="Anthropic Claude"/>
                            <ComboBoxItem Content="Mistral AI"/>
                            <ComboBoxItem Content="Groq"/>
                            <ComboBoxItem Content="Ollama"/>
                        </ComboBox>

                        <Separator Margin="0,16" Opacity="0.15"/>

                        <!-- API Key Input -->
                        <TextBlock Text="API Key" FontSize="14" FontWeight="Medium"/>
                        <TextBlock Text="Enter your API key for the selected provider. Keys are stored locally." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,8" TextWrapping="Wrap"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="AiApiKeyInput" PlaceholderText="Paste your API key here..." Margin="0,0,8,0"/>
                            <ui:Button Grid.Column="1" Content="Validate" Appearance="Secondary" Click="ValidateAiKey_Click" Margin="0,0,8,0" ToolTip="Test the key with a small API call"/>
                            <ui:Button Grid.Column="2" Content="Save" Appearance="Primary" Click="SaveAiKey_Click"/>
                        </Grid>
                        <TextBlock x:Name="AiKeyStatus" Text="" FontSize="12" Margin="0,6,0,0" Foreground="#A6E3A1"/>

                        <Separator Margin="0,16" Opacity="0.15"/>

                        <!-- Advanced Model Configuration -->
                        <TextBlock Text="Model Name" FontSize="14" FontWeight="Medium"/>
                        <TextBlock Text="Leave empty to use the recommended default model for this provider." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,8" TextWrapping="Wrap"/>
                        <ComboBox x:Name="AiModelCombo" 
                                  IsEditable="True" 
                                  Width="260" 
                                  HorizontalAlignment="Left" 
                                  Margin="0,0,0,12" 
                                  SelectionChanged="AiModelCombo_SelectionChanged"
                                  TextBoxBase.TextChanged="AiModelCombo_TextChanged"/>


                        <StackPanel x:Name="EndpointUrlPanel" Visibility="Collapsed">
                            <TextBlock Text="Endpoint URL" FontSize="14" FontWeight="Medium"/>
                            <TextBlock Text="Override the default API endpoint. Required for local models like Ollama." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,8" TextWrapping="Wrap"/>
                            <ui:TextBox x:Name="AiEndpointUrlInput" PlaceholderText="e.g. http://localhost:11434/api/chat" Margin="0,0,0,16"/>
                        </StackPanel>

                        <Separator Margin="0,16" Opacity="0.15"/>

                        <!-- Toggles -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Enable AI Summarization" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="When enabled, you'll be prompted to generate a summary after each server session." 
                                           TextWrapping="Wrap" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                           FontSize="12" 
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleAiSummarization" Grid.Column="1" VerticalAlignment="Center" 
                                             Checked="ToggleAiSummarization_Changed" 
                                             Unchecked="ToggleAiSummarization_Changed"/>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Automatic Summarization" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Skip the confirmation dialog and always generate summaries automatically." 
                                           TextWrapping="Wrap" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                           FontSize="12" 
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleAutoSummarize" Grid.Column="1" VerticalAlignment="Center" 
                                             Checked="ToggleAutoSummarize_Changed" 
                                             Unchecked="ToggleAutoSummarize_Changed"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon Stethoscope24}">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Diagnostics &amp; Support" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Tools to help troubleshoot and report issues." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16">
                        <!-- Dependency Health -->
                        <TextBlock Text="External Services Availability" FontSize="14" FontWeight="Medium" Margin="0,0,0,4"/>
                        <ItemsControl x:Name="DependencyHealthList" Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{Binding ColorBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Details}" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,4,0,12" Opacity="0.15"/>

                        <!-- Disaster Recovery -->
                        <TextBlock Text="Disaster Recovery (Off-site Prep)" FontSize="14" FontWeight="Medium"/>
                        <TextBlock Text="Set a secondary external location (like a Google Drive or USB directory) where world backups should be replicated automatically when they run." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,12" TextWrapping="Wrap"/>
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <ui:TextBox x:Name="ExternalBackupPathInput" PlaceholderText="Select an external path..." IsReadOnly="True" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ui:Button Grid.Column="1" Content="Browse" Click="BrowseExternalBackup_Click" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ui:Button Grid.Column="2" Content="Save" Appearance="Primary" Click="SaveExternalBackup_Click" VerticalAlignment="Center"/>
                        </Grid>

                        <Separator Margin="0,4,0,12" Opacity="0.15"/>

                        <TextBlock Text="Export Support Bundle" FontSize="14" FontWeight="Medium"/>
                        <TextBlock Text="Generates a ZIP archive containing redacted App logs, system information, and running server metrics. Attach this to GitHub issues or Discord help requests." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,12" TextWrapping="Wrap"/>
                        <ui:Button x:Name="BtnExportBundle" Content="Generate Support Bundle" Icon="{ui:SymbolIcon Archive24}" Appearance="Secondary" Click="ExportBundle_Click"/>
                        <TextBlock x:Name="ExportBundleStatusText" FontSize="12" Margin="0,8,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </ui:CardExpander>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
