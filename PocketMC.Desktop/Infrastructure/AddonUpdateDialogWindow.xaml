<ui:FluentWindow x:Class="PocketMC.Desktop.Infrastructure.AddonUpdateDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Addon Updates"
        Width="560"
        SizeToContent="Height"
        MinWidth="480" MaxWidth="640"
        MinHeight="0" MaxHeight="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowCornerPreference="Round"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="None"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="20" MaxWidth="600">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="⬆" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="#89B4FA"/>
            <TextBlock x:Name="TxtTitle" Text="Available Updates"
                       FontSize="16" FontWeight="Bold"
                       Foreground="#89B4FA"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Summary text -->
        <TextBlock Grid.Row="1" x:Name="TxtSummary"
                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,10" TextWrapping="Wrap"/>

        <!-- Select All checkbox -->
        <CheckBox Grid.Row="2" x:Name="ChkSelectAll" Content="Select All"
                  IsChecked="True" Margin="0,0,0,6"
                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                  Checked="ChkSelectAll_Changed" Unchecked="ChkSelectAll_Changed"/>

        <!-- Update items list -->
        <Border Grid.Row="3" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="6" Padding="0"
                MaxHeight="360">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ItemsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Checkbox -->
                                    <CheckBox Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              IsEnabled="{Binding CanSelect}"
                                              VerticalAlignment="Center" Margin="0,0,8,0"/>

                                    <!-- Name + version info -->
                                    <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Margin="8,0,0,0" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   VerticalAlignment="Center">
                                            <Run Text="{Binding InstalledVersion, Mode=OneWay}"/>
                                            <Run Text=" → "/>
                                            <Run Text="{Binding LatestVersion, Mode=OneWay}" Foreground="#A6E3A1"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Status text -->
                                    <TextBlock Grid.Column="1" Grid.Row="1"
                                               Text="{Binding StatusText}" FontSize="11"
                                               Foreground="{Binding StatusForeground}"
                                               Margin="0,2,0,0"
                                               Visibility="{Binding HasStatus, Converter={StaticResource VisibleIfTrue}}"/>

                                    <!-- Progress bar -->
                                    <ProgressBar Grid.Column="1" Grid.Row="2"
                                                 Value="{Binding ProgressValue}"
                                                 Minimum="0" Maximum="100"
                                                 Height="4" Margin="0,4,0,0"
                                                 Foreground="#89B4FA"
                                                 Visibility="{Binding IsDownloading, Converter={StaticResource VisibleIfTrue}}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Overall progress -->
        <StackPanel Grid.Row="4" Margin="0,10,0,0">
            <TextBlock x:Name="TxtOverallStatus" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Visibility="Collapsed"/>
            <ProgressBar x:Name="OverallProgressBar"
                         Height="4" Margin="0,4,0,0"
                         Minimum="0" Maximum="100"
                         Foreground="#A6E3A1"
                         Visibility="Collapsed"/>
        </StackPanel>

        <!-- Buttons -->
        <WrapPanel Grid.Row="5" HorizontalAlignment="Right" Margin="0,14,0,0">
            <ui:Button x:Name="BtnCancel" Content="Cancel"
                       MinWidth="80" Margin="0,0,8,0"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Click="BtnCancel_Click"/>
            <ui:Button x:Name="BtnUpdate" Content="Update Selected"
                       Appearance="Primary" MinWidth="120"
                       Foreground="White" FontWeight="SemiBold"
                       Click="BtnUpdate_Click" IsDefault="True"/>
        </WrapPanel>
    </Grid>
</ui:FluentWindow>
