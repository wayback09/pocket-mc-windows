<ui:FluentWindow x:Class="PocketMC.Desktop.Features.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:dash="clr-namespace:PocketMC.Desktop.Features.Dashboard"
        xmlns:tunnel="clr-namespace:PocketMC.Desktop.Features.Tunnel"
        xmlns:setup="clr-namespace:PocketMC.Desktop.Features.Setup"
        xmlns:shell="clr-namespace:PocketMC.Desktop.Features.Shell"
        xmlns:remote="clr-namespace:PocketMC.Desktop.Features.RemoteControl.UI"
        xmlns:tb="clr-namespace:Hardcodet.Wpf.TaskbarNotification;assembly=Hardcodet.NotifyIcon.Wpf"
        xmlns:helpers="clr-namespace:PocketMC.Desktop.Helpers"
        mc:Ignorable="d"
        Title="PocketMC Desktop"
        WindowBackdropType="None"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/icon.ico"
        Background="#FF242424"
        Loaded="Window_Loaded"
        Activated="Window_Activated"
        Deactivated="Window_Deactivated">

    <Grid>
        <!-- Fake Mica: blurred wallpaper layer (collapsed until FakeMica theme is selected) -->
        <Image x:Name="WallpaperBlurLayer"
               Visibility="Collapsed"
               IsHitTestVisible="False"
               Stretch="UniformToFill"/>
        <Border x:Name="WallpaperTintOverlay"
                Visibility="Collapsed"
                IsHitTestVisible="False"/>

        <Border x:Name="BackdropTintLayer"
                Background="#CC202020"
                IsHitTestVisible="False"/>

        <!-- TRAY ICON -->
        <tb:TaskbarIcon x:Name="AppTrayIcon"
                        IconSource="pack://application:,,,/icon.ico"
                        ToolTipText="{Binding TooltipText}"
                        Visibility="{Binding IconVisibility}"
                        TrayMouseDoubleClick="AppTrayIcon_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open Dashboard" Click="TrayOpen_Click"/>
                    <MenuItem Header="Exit PocketMC" Click="TrayExit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- Root layout: update banner stacked above the nav shell -->
        <Grid>
            <Grid.RowDefinitions>
                <!-- Update notification banner — collapses when no update is staged -->
                <RowDefinition Height="Auto"/>
                <!-- Main navigation shell -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ─── Update Banner ─────────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Visibility="{Binding IsUpdateBannerVisible, Converter={StaticResource BoolToVis}}"
                    Background="#2563EB"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status text + progress -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Spinner while downloading -->
                        <ui:ProgressRing Width="14" Height="14"
                                         IsIndeterminate="True"
                                         Margin="0,0,8,0"
                                         Visibility="{Binding IsUpdateDownloading, Converter={StaticResource BoolToVis}}"/>

                        <!-- Download progress bar -->
                        <ProgressBar Width="120" Height="6"
                                     Minimum="0" Maximum="100"
                                     Value="{Binding UpdateDownloadPercent, Mode=OneWay}"
                                     Margin="0,0,10,0"
                                     Visibility="{Binding IsUpdateDownloading, Converter={StaticResource BoolToVis}}"/>

                        <!-- Message -->
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding UpdateStatusMessage}"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="Medium"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <!-- "Restart now" button — only shown when update is fully downloaded -->
                        <ui:Button Content="Restart to update"
                                   Appearance="Secondary"
                                   Margin="12,0,8,0"
                                   Padding="10,4"
                                   Command="{Binding RestartAndApplyUpdateCommand}"
                                   ToolTip="Stop all servers first if any are running"
                                   Visibility="{Binding IsUpdateReadyToApply, Converter={StaticResource BoolToVis}}"/>

                        <!-- Dismiss -->
                        <ui:Button Icon="{ui:SymbolIcon Dismiss16}"
                                   Appearance="Transparent"
                                   Padding="4"
                                   Command="{Binding DismissUpdateBannerCommand}"
                                   ToolTip="Dismiss — update will apply on next restart"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ─── NavigationView shell ──────────────────────────────────────── -->
            <ui:NavigationView x:Name="RootNavigation"
                               Grid.Row="1"
                               helpers:AnimatedNavIndicatorBehavior.IsEnabled="True"
                               PaneDisplayMode="Left"
                               IsBackButtonVisible="Collapsed"
                               IsPaneToggleVisible="{Binding IsPaneToggleVisible}"
                               IsPaneVisible="{Binding IsPaneVisible}"
                               OpenPaneLength="240"
                               ScrollViewer.VerticalScrollBarVisibility="Disabled"
                               ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <!-- ─── Title Bar ─── -->
                <ui:NavigationView.Header>
                    <ui:TitleBar Title="PocketMC Desktop"
                                 ShowMaximize="True"
                                 ShowMinimize="True"
                                 ShowClose="True">
                        <ui:TitleBar.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Context for detail pages like Console -->
                                <Border x:Name="TitleBarContextBorder"
                                        Grid.Column="1"
                                        Background="#12FFFFFF"
                                        CornerRadius="4"
                                        Padding="10,3"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding TitleBarContextVisibility}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="TitleBarContextTitle"
                                                   Text="{Binding TitleBarTitle}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TitleBarContextSeparator"
                                                   Text="  •  "
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorDisabledBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TitleBarContextStatus"
                                                   Text="{Binding TitleBarStatusText}"
                                                   Foreground="{Binding TitleBarStatusBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Global resource health pill -->
                                <Border x:Name="GlobalHealthBorder"
                                        Grid.Column="2"
                                        Background="#18FFFFFF"
                                        CornerRadius="4"
                                        Padding="10,3"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding GlobalHealthVisibility}">
                                    <TextBlock x:Name="GlobalHealthTextBlock"
                                               Text="{Binding GlobalHealthStatusText}"
                                               Foreground="{Binding GlobalHealthStatusBrush, FallbackValue=Silver}"
                                               FontSize="11"/>
                                </Border>
                            </Grid>
                        </ui:TitleBar.Header>
                    </ui:TitleBar>
                </ui:NavigationView.Header>

                <!-- ─── Sidebar Items ─── -->
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem x:Name="NavDashboard"
                                           Content="Dashboard"
                                           Icon="{ui:SymbolIcon Home24}"
                                           TargetPageType="{x:Type dash:DashboardPage}"/>
                    <ui:NavigationViewItem x:Name="NavTunnel"
                                           Content="Tunnel"
                                           Icon="{ui:SymbolIcon Globe24}"
                                           TargetPageType="{x:Type tunnel:TunnelPage}"/>
                    <ui:NavigationViewItem x:Name="NavRemoteControl"
                                           Content="Remote Control"
                                           Icon="{ui:SymbolIcon PhoneDesktop24}"
                                           TargetPageType="{x:Type remote:RemoteControlPage}"/>
                </ui:NavigationView.MenuItems>

                <!-- ─── Footer ─── -->
                <ui:NavigationView.FooterMenuItems>
                    <ui:NavigationViewItem x:Name="NavSettings"
                                           Content="Settings"
                                           Icon="{ui:SymbolIcon Settings24}"
                                           TargetPageType="{x:Type setup:AppSettingsPage}"/>
                    <ui:NavigationViewItem x:Name="NavJavaSetup"
                                           Content="Java Setup"
                                           Icon="{ui:SymbolIcon ArrowDownload24}"
                                           TargetPageType="{x:Type setup:JavaSetupPage}"/>
                    <ui:NavigationViewItem x:Name="NavAbout"
                                           Content="About"
                                           Icon="{ui:SymbolIcon Info24}"
                                           TargetPageType="{x:Type shell:AboutPage}"/>
                </ui:NavigationView.FooterMenuItems>

            </ui:NavigationView>
        </Grid>
    </Grid>

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>
</ui:FluentWindow>
