<Page x:Class="PocketMC.Desktop.Features.Settings.ServerSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:intel="clr-namespace:PocketMC.Desktop.Features.Intelligence"
      xmlns:infra="clr-namespace:PocketMC.Desktop.Infrastructure"
      mc:Ignorable="d"
      d:DesignHeight="1200" d:DesignWidth="950"
      Title="Server Settings"
      Background="Transparent">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="VisibleIfTrue"/>
        <presentation:InverseBooleanToVisibilityConverter x:Key="InvertedVisibilityConverter" xmlns:presentation="clr-namespace:PocketMC.Desktop.Core.Presentation"/>
        <presentation:InverseBooleanConverter x:Key="InvertedBooleanConverter" xmlns:presentation="clr-namespace:PocketMC.Desktop.Core.Presentation"/>
        <settings:MinecraftMotdConverter x:Key="MotdConverter" xmlns:settings="clr-namespace:PocketMC.Desktop.Features.Settings"/>

        <ImageBrush x:Key="DirtBackground" ImageSource="pack://application:,,,/Assets/dark_dirt.png" Viewport="0,0,45,46" ViewportUnits="Absolute" TileMode="Tile" Stretch="Fill" />

        <!-- Premium Styles -->
        <Style TargetType="{x:Type ui:TextBox}" BasedOn="{StaticResource {x:Type ui:TextBox}}">
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="{x:Type ui:ToggleSwitch}" BasedOn="{StaticResource {x:Type ui:ToggleSwitch}}">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,6,0,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="SettingsHeader">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="SettingsSubtext">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Page.Resources>

    <Grid Margin="28,20,28,24" VerticalAlignment="Stretch">
        <DockPanel LastChildFill="True">

            <!-- Title Section -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:Button Icon="{ui:SymbolIcon ArrowLeft24}"
                               Appearance="Transparent"
                               Command="{Binding CancelCommand}"
                               Margin="0,0,12,0"
                               Padding="6" />
                    <ui:TextBlock FontTypography="Title"
                                  Text="Server Configurations"
                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                  VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Modify your instance setup, install addons, configure automated tasks and manage world files."
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="13"
                           Margin="48,0,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Bottom Action Bar -->
            <Border DockPanel.Dock="Bottom"
                    Margin="0,16,0,0"
                    Padding="20,16"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Visibility="{Binding IsVersionUpdatesTabActive, Converter={StaticResource VisibleIfTrue}}">
                            <TextBlock Text="{Binding VersionUpdates.StatusText}"
                                       Foreground="#89B4FA"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <StackPanel Margin="0,8,24,0"
                                        Visibility="{Binding VersionUpdates.IsUpdateProgressVisible, Converter={StaticResource VisibleIfTrue}}">
                                <ProgressBar Value="{Binding VersionUpdates.UpdateProgressValue}"
                                             Maximum="100"
                                             Height="5"
                                             Width="420"
                                             HorizontalAlignment="Left"
                                             IsIndeterminate="{Binding VersionUpdates.IsUpdateProgressIndeterminate}"/>
                                <TextBlock Text="{Binding VersionUpdates.ProgressDetailText}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="11"
                                           Margin="0,5,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="{Binding HasUnsavedChanges, Converter={StaticResource VisibleIfTrue}}">
                            <ui:SymbolIcon Symbol="Warning24" Foreground="#F38BA8" Margin="0,0,10,0"/>
                            <TextBlock Text="Unsaved changes detected"
                                       Foreground="#F38BA8"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="{Binding IsRestartRequired, Converter={StaticResource VisibleIfTrue}}">
                            <ui:SymbolIcon Symbol="ArrowClockwise24" Foreground="#89B4FA" Margin="0,0,10,0"/>
                            <TextBlock Text="Server restart required to apply changes"
                                       Foreground="#89B4FA"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsVersionUpdatesTabActive, Converter={StaticResource VisibleIfTrue}}">
                            <ui:Button Content="Preview Update" Appearance="Secondary" Command="{Binding VersionUpdates.PlanCommand}" Margin="0,0,10,0" Icon="{ui:SymbolIcon Search20}"/>
                            <ui:Button Content="Apply Update" Appearance="Primary" Command="{Binding VersionUpdates.ApplyCommand}" Margin="0,0,10,0" Icon="{ui:SymbolIcon ArrowSync20}"/>
                            <ui:Button Content="Rollback" Appearance="Secondary" Command="{Binding VersionUpdates.RollbackCommand}" Margin="0,0,16,0" Icon="{ui:SymbolIcon ArrowUndo20}"/>
                        </StackPanel>
                        <ui:Button Content="Discard" Appearance="Secondary" Margin="0,0,12,0" Command="{Binding CancelCommand}"/>
                        <ui:Button Content="Save Changes" Appearance="Primary" Command="{Binding SaveCommand}" MinWidth="140"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Layout Grid -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ui:NavigationView Grid.Column="0"
                                   x:Name="SidebarList"
                                   PaneDisplayMode="Left"
                                   IsPaneToggleVisible="False"
                                   IsBackButtonVisible="Collapsed">
                    <ui:NavigationView.MenuItems>
                        <ui:NavigationViewItem Content="Identity &amp; Performance" Icon="{ui:SymbolIcon Settings24}" Click="NavItem_Click" IsActive="True"/>
                        <ui:NavigationViewItem Content="Version &amp; Updates" Icon="{ui:SymbolIcon ArrowSync24}" Click="NavItem_Click"/>
                        <ui:NavigationViewItem Content="Gameplay Rules" Icon="{ui:SymbolIcon Globe24}" Click="NavItem_Click"/>
                        <ui:NavigationViewItem Content="World &amp; Files" Icon="{ui:SymbolIcon Folder24}" Click="NavItem_Click"/>
                        <ui:NavigationViewItem Content="Addons (Plugins/Mods)" Icon="{ui:SymbolIcon Add24}" Click="NavItem_Click"/>
                        <ui:NavigationViewItem Content="Automated Backups" Icon="{ui:SymbolIcon Save24}" Click="NavItem_Click"/>
                        <ui:NavigationViewItem Content="Fault Tolerance" Icon="{ui:SymbolIcon ArrowSync24}" Click="NavItem_Click"/>
                        <ui:NavigationViewItem Content="Advanced Editor" Icon="{ui:SymbolIcon Code24}" Click="NavItem_Click"/>
                        <ui:NavigationViewItem Content="AI Summaries" Icon="{ui:SymbolIcon BrainCircuit24}" Click="NavItem_Click"
                                               Visibility="{Binding IsAiSummarizationAvailable, Converter={StaticResource VisibleIfTrue}}"/>
                    </ui:NavigationView.MenuItems>
                </ui:NavigationView>

                <Border x:Name="ContentAreaCard" Grid.Column="2" VerticalAlignment="Stretch">
                    <TabControl x:Name="MainTabControl" Background="Transparent" BorderThickness="0" Margin="0" VerticalAlignment="Stretch">
                        <TabControl.Resources><Style TargetType="TabPanel"><Setter Property="Visibility" Value="Collapsed"/></Style></TabControl.Resources>

                        <!-- TAB 1: IDENTITY & PERFORMANCE -->
                        <TabItem Header="Identity">
                            <ScrollViewer x:Name="GeneralScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                                <StackPanel>
                                    <ui:CardExpander Header="Visual Identity" Icon="{ui:SymbolIcon Settings24}" Margin="0,0,0,12" IsExpanded="True">
                                        <StackPanel Margin="16,8,16,16">
                                            <!-- Instance Alias & Description -->
                                            <TextBlock Text="Instance Name (Label)" Style="{StaticResource SettingsHeader}" Margin="0,0,0,4"/>
                                            <TextBlock Text="The display name for this instance in your dashboard." Style="{StaticResource SettingsSubtext}" Margin="0,0,0,8"/>
                                            <ui:TextBox Text="{Binding General.InstanceName, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="My Epic Server" Margin="0,0,0,16"/>

                                            <TextBlock Text="Instance Description" Style="{StaticResource SettingsHeader}" Margin="0,0,0,4"/>
                                            <TextBlock Text="A short note about this instance's purpose or configuration." Style="{StaticResource SettingsSubtext}" Margin="0,0,0,8"/>
                                            <ui:TextBox Text="{Binding General.InstanceDescription, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Testing new mods..." Margin="0,0,0,20"/>

                                            <Separator Margin="0,0,0,20" Opacity="0.15"/>

                                            <!-- Startup Auto-Start -->
                                            <TextBlock Text="Auto-Start on Application Launch" Style="{StaticResource SettingsHeader}" Margin="0,0,0,4"/>
                                            <TextBlock Text="Automatically start this specific server instance when PocketMC starts." Style="{StaticResource SettingsSubtext}" Margin="0,0,0,8"/>
                                            <ui:ToggleSwitch IsChecked="{Binding General.AutoStartWithApp, Mode=TwoWay}" Content="Auto-start server at PocketMC startup" Margin="0,0,0,20"/>

                                            <Separator Margin="0,0,0,20" Opacity="0.15"/>

                                            <!-- Interactive Dummy Server Card -->
                                            <Border Background="{StaticResource DirtBackground}" BorderThickness="2" BorderBrush="#000000" Padding="4" Margin="0,0,0,16" CornerRadius="0"
                                                    Visibility="{Binding IsJavaSettings, Converter={StaticResource VisibleIfTrue}}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/> <!-- Server Icon -->
                                                        <ColumnDefinition Width="6"/> <!-- Tight Spacing -->
                                                        <ColumnDefinition Width="*"/> <!-- Server Info & MOTD -->
                                                        <ColumnDefinition Width="Auto"/> <!-- Action Buttons -->
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Icon area with Edit Hover -->
                                                    <Grid Grid.Column="0" Width="64" Height="64">
                                                        <Border BorderThickness="1" BorderBrush="#333333" Background="#111">
                                                            <Image Source="{Binding General.ServerIcon}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Border>
                                                        <ui:Button Appearance="Primary" Padding="4" Command="{Binding General.BrowseIconCommand}" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="-8,-8,0,0" ToolTip="Change Server Icon">
                                                            <ui:SymbolIcon Symbol="Edit16" />
                                                        </ui:Button>
                                                    </Grid>

                                                    <Grid Grid.Column="2">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/> <!-- Top row: Name -->
                                                            <RowDefinition Height="*"/> <!-- Bottom row: MOTD -->
                                                        </Grid.RowDefinitions>

                                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,-2,0,2">
                                                            <!-- Server Name (Bound to InstanceName) -->
                                                            <TextBlock Text="{Binding General.InstanceName, FallbackValue='Minecraft Server'}" FontFamily="Consolas" FontSize="15" Foreground="White" FontWeight="SemiBold">
                                                                <TextBlock.Effect>
                                                                    <DropShadowEffect BlurRadius="0" ShadowDepth="2" Opacity="1" Color="Black" />
                                                                </TextBlock.Effect>
                                                            </TextBlock>
                                                        </StackPanel>

                                                        <!-- MOTD Display & Editor -->
                                                        <Grid Grid.Row="1" VerticalAlignment="Top">

                                                            <!-- Display Mode -->
                                                            <StackPanel x:Name="MotdDisplayMode">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <ContentControl Content="{Binding General.Motd, Converter={StaticResource MotdConverter}}" FontFamily="Consolas" FontSize="14">
                                                                        <ContentControl.Effect>
                                                                            <DropShadowEffect BlurRadius="0" ShadowDepth="2" Opacity="1" Color="Black" />
                                                                        </ContentControl.Effect>
                                                                    </ContentControl>
                                                                    <ui:Button Appearance="Transparent" Icon="{ui:SymbolIcon Edit16}" Click="BtnEditMotd_Click" Margin="4,-2,0,0" Padding="2" ToolTip="Edit MOTD"/>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <!-- MOTD Editor Mode -->
                                                            <StackPanel x:Name="MotdEditorMode" Visibility="Collapsed" Margin="0,0,0,0">
                                                                <WrapPanel Margin="0,0,0,4" MaxWidth="280">
                                                                    <!-- Colors -->
                                                                    <Button Content="&#167;4" ToolTip="Dark Red" Click="BtnInsertMotdColor_Click" Tag="&#167;4" Background="#AA0000" Foreground="White" BorderThickness="0" Margin="0,0,2,2" Padding="2" FontFamily="Consolas" Cursor="Hand"/>
                                                                    <Button Content="&#167;c" ToolTip="Red" Click="BtnInsertMotdColor_Click" Tag="&#167;c" Background="#FF5555" Foreground="White" BorderThickness="0" Margin="0,0,2,2" Padding="2" FontFamily="Consolas" Cursor="Hand"/>
                                                                    <Button Content="&#167;6" ToolTip="Gold" Click="BtnInsertMotdColor_Click" Tag="&#167;6" Background="#FFAA00" Foreground="White" BorderThickness="0" Margin="0,0,2,2" Padding="2" FontFamily="Consolas" Cursor="Hand"/>
                                                                    <Button Content="&#167;e" ToolTip="Yellow" Click="BtnInsertMotdColor_Click" Tag="&#167;e" Background="#FFFF55" Foreground="Black" BorderThickness="0" Margin="0,0,2,2" Padding="2" FontFamily="Consolas" Cursor="Hand"/>
                                                                    <Button Content="&#167;2" ToolTip="Dark Green" Click="BtnInsertMotdColor_Click" Tag="&#167;2" Background="#00AA00" Foreground="White" BorderThickness="0" Margin="0,0,2,2" Padding="2" FontFamily="Consolas" Cursor="Hand"/>
                                                                    <Button Content="&#167;a" ToolTip="Green" Click="BtnInsertMotdColor_Click" Tag="&#167;a" Background="#55FF55" Foreground="Black" BorderThickness="0" Margin="0,0,2,2" Padding="2" FontFamily="Consolas" Cursor="Hand"/>
                                                                    <Button Content="&#167;b" ToolTip="Aqua" Click="BtnInsertMotdColor_Click" Tag="&#167;b" Background="#55FFFF" Foreground="Black" BorderThickness="0" Margin="0,0,2,2" Padding="2" FontFamily="Consolas" Cursor="Hand"/>
                                                                    <Button Content="&#167;1" ToolTip="Dark Blue" Click="BtnInsertMotdColor_Click" Tag="&#167;1" Background="#0000AA" Foreground="White" BorderThickness="0" Margin="0,0,2,2" Padding="2" FontFamily="Consolas" Cursor="Hand"/>
                                                                    <Button Content="&#167;d" ToolTip="Light Purple" Click="BtnInsertMotdColor_Click" Tag="&#167;d" Background="#FF55FF" Foreground="White" BorderThickness="0" Margin="0,0,2,2" Padding="2" FontFamily="Consolas" Cursor="Hand"/>
                                                                    <Button Content="&#167;f" ToolTip="White" Click="BtnInsertMotdColor_Click" Tag="&#167;f" Background="#FFFFFF" Foreground="Black" BorderThickness="0" Margin="0,0,2,2" Padding="2" FontFamily="Consolas" Cursor="Hand"/>
                                                                    <Button Content="&#167;0" ToolTip="Black" Click="BtnInsertMotdColor_Click" Tag="&#167;0" Background="#000000" Foreground="White" BorderThickness="0" Margin="0,0,8,2" Padding="2" FontFamily="Consolas" Cursor="Hand"/>

                                                                    <!-- Formatters -->
                                                                    <Button Content="&#167;l" ToolTip="Bold" Click="BtnInsertMotdColor_Click" Tag="&#167;l" Background="#333" Foreground="Silver" BorderThickness="0" Margin="0,0,2,2" Padding="2" FontFamily="Consolas" FontWeight="Bold" Cursor="Hand"/>
                                                                    <Button Content="&#167;n" ToolTip="Underline" Click="BtnInsertMotdColor_Click" Tag="&#167;n" Background="#333" Foreground="Silver" BorderThickness="0" Margin="0,0,2,2" Padding="2" FontFamily="Consolas" Cursor="Hand"/>
                                                                    <Button Content="&#167;r" ToolTip="Reset" Click="BtnInsertMotdColor_Click" Tag="&#167;r" Background="#333" Foreground="Silver" BorderThickness="0" Margin="0,0,2,2" Padding="2" FontFamily="Consolas" Cursor="Hand"/>
                                                                </WrapPanel>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <ui:TextBox x:Name="TxtMotdRaw" Text="{Binding General.Motd, UpdateSourceTrigger=PropertyChanged}" Width="280" FontFamily="Consolas"/>
                                                                    <ui:Button Appearance="Primary" Icon="{ui:SymbolIcon Checkmark16}" Click="BtnSaveMotd_Click" Margin="6,0,0,0" ToolTip="Save"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>

                                                    <!-- Signal Bars Dummy -->
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Top" Margin="8,0,4,0">
                                                        <TextBlock FontSize="15" FontFamily="Consolas" Foreground="#AAAAAA" VerticalAlignment="Top" Margin="0,0,6,0" FontWeight="SemiBold">
                                                            <Run Text="0/"/><Run Text="{Binding World.MaxPlayers, FallbackValue=20}"/>
                                                            <TextBlock.Effect>
                                                                <DropShadowEffect BlurRadius="0" ShadowDepth="2" Opacity="1" Color="Black"/>
                                                            </TextBlock.Effect>
                                                        </TextBlock>
                                                        <Grid Width="16" Height="14" VerticalAlignment="Top" Margin="0,2,0,0">
                                                            <Rectangle Width="3" Height="4" Fill="#00FF00" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                                                            <Rectangle Width="3" Height="7" Fill="#00FF00" HorizontalAlignment="Left" Margin="4,0,0,0" VerticalAlignment="Bottom"/>
                                                            <Rectangle Width="3" Height="10" Fill="#00FF00" HorizontalAlignment="Left" Margin="8,0,0,0" VerticalAlignment="Bottom"/>
                                                            <Rectangle Width="3" Height="14" Fill="#00FF00" HorizontalAlignment="Left" Margin="12,0,0,0" VerticalAlignment="Bottom"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- Simple MOTD Editor (Non-Java) -->
                                            <StackPanel Margin="0,0,0,16" Visibility="{Binding IsJavaSettings, Converter={StaticResource InvertedVisibilityConverter}}">
                                                <TextBlock Text="{Binding DisplayNameLabel, FallbackValue='Server Message (MOTD)'}" Style="{StaticResource SettingsHeader}" Margin="0,0,0,4"/>
                                                <TextBlock Text="The message displayed to players in the server list." Style="{StaticResource SettingsSubtext}" Margin="0,0,0,8"/>
                                                <ui:TextBox Text="{Binding General.Motd, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="My Server" />
                                            </StackPanel>

                                        </StackPanel>
                                    </ui:CardExpander>

                                    <!-- NETWORKING & IP -->
                                    <ui:CardExpander Header="Networking &amp; IP" Icon="{ui:SymbolIcon Globe24}" Margin="0,0,0,12" IsExpanded="True">
                                        <StackPanel Margin="16,8,16,16">

                                            <!-- Server Port -->
                                            <TextBlock Text="Server Port" Style="{StaticResource SettingsHeader}" Margin="0,0,0,4"/>
                                            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8">
                                                <Run Text="The port your Minecraft server listens on. Default is "/>
                                                <Run Text="{Binding DefaultServerPortText, Mode=OneWay}"/>
                                                <Run Text="."/>
                                            </TextBlock>
                                            <ui:TextBox Text="{Binding General.ServerPort, UpdateSourceTrigger=PropertyChanged}"
                                                        PlaceholderText="{Binding DefaultServerPortText, Mode=OneWay}" Width="160" HorizontalAlignment="Left"/>

                                            <StackPanel Visibility="{Binding SupportsGeyserSettings, Converter={StaticResource BoolToVis}}">
                                                <Separator Margin="0,16" Opacity="0.15"/>

                                                <TextBlock Text="Geyser Bedrock Port (UDP)" Style="{StaticResource SettingsHeader}" Margin="0,0,0,4"/>
                                                <TextBlock Text="The UDP port used by Bedrock players to connect via Geyser."
                                                           FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>
                                                <ui:TextBox Text="{Binding General.GeyserBedrockPort, UpdateSourceTrigger=PropertyChanged}"
                                                            PlaceholderText="19132" Width="160" HorizontalAlignment="Left"/>
                                            </StackPanel>

                                            <Separator Margin="0,16" Opacity="0.15"/>
                                            <!-- Public IP / Tunnel Endpoint -->
                                            <TextBlock Text="Public Address (Tunnel)" Style="{StaticResource SettingsHeader}" Margin="0,0,0,4"/>
                                            <TextBlock Text="The public address players use to connect. Resolved from your active Playit.gg tunnels."
                                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" TextWrapping="Wrap"/>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Primary Java Tunnel -->
                                                    <Border Grid.Row="0" Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                            BorderThickness="1" CornerRadius="4" Padding="12,8" VerticalAlignment="Center">
                                                        <StackPanel>
                                                            <TextBlock x:Name="TxtPlayitAddress" Text="{Binding PlayitAddress}"
                                                                       FontFamily="Consolas" FontSize="14"
                                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Secondary Bedrock Tunnel -->
                                                    <Border Grid.Row="1" Background="#22F9A825"
                                                            BorderBrush="#44F9A825" Margin="0,8,0,0"
                                                            BorderThickness="1" CornerRadius="4" Padding="12,8" VerticalAlignment="Center"
                                                            Visibility="{Binding HasGeyser, Converter={StaticResource VisibleIfTrue}}">
                                                        <StackPanel>
                                                            <TextBlock Text="Bedrock Address:" FontSize="11" Foreground="#F9A825" Margin="0,0,0,2"/>
                                                            <TextBlock x:Name="TxtPlayitBedrockAddress" Text="{Binding PlayitBedrockAddress}"
                                                                       FontFamily="Consolas" FontSize="14"
                                                                       Foreground="#FFD54F"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>

                                                <ui:Button Grid.Column="1" Appearance="Secondary"
                                                           Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}"
                                                           Command="{Binding ResolvePlayitCommand}"
                                                           Margin="8,0,0,0" VerticalAlignment="Center" ToolTip="Re-resolve tunnel address for current port"/>
                                            </Grid>



                                        </StackPanel>
                                    </ui:CardExpander>

                                            <ui:CardExpander Header="Resource Allocation" Icon="{ui:SymbolIcon TopSpeed24}" Margin="0,0,0,12" IsExpanded="True"
                                                             Visibility="{Binding SupportsJavaRuntimeSettings, Converter={StaticResource VisibleIfTrue}}">
                                        <StackPanel Margin="16,8,16,16">
                                            <TextBlock Text="System RAM Limit:" Style="{StaticResource SettingsHeader}"/>
                                            <Grid Margin="0,5,0,15">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="0.5GB" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="11"/>
                                                <Slider Grid.Column="1" Value="{Binding Performance.MaxRam}" Minimum="512" Maximum="{Binding Performance.TotalRamMb}" TickFrequency="512" SmallChange="512" LargeChange="1024" IsSnapToTickEnabled="True"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Performance.MaxRamDisplay}" Margin="12,0,0,0" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </Grid>

                                            <TextBlock Text="Startup JVM Arguments:" Style="{StaticResource SettingsHeader}" Margin="0,5,0,8"/>
                                            <ui:TextBox Text="{Binding Performance.AdvancedJvmArgs, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="-XX:+UseG1GC ..."/>

                                            <TextBlock Text="Custom Java Executable:" Style="{StaticResource SettingsHeader}" Margin="0,15,0,8"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <ui:TextBox Text="{Binding Performance.JavaPath, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Internal Java 17/21"/>
                                                <ui:Button Grid.Column="1" Content="Browse" Command="{Binding Performance.BrowseJavaCommand}" Margin="8,0,0,0"/>
                                            </Grid>
                                        </StackPanel>
                                    </ui:CardExpander>

                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- TAB 2: VERSION & UPDATES -->
                        <TabItem Header="VersionUpdates">
                            <ScrollViewer x:Name="VersionUpdatesScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                                <StackPanel>
                                    <ui:Card Padding="24" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Version &amp; Updates" Style="{StaticResource SettingsHeader}" FontSize="18"/>
                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Current server version" Style="{StaticResource SettingsSubtext}"/>
                                                    <TextBlock Text="{Binding VersionUpdates.CurrentServerVersion}" FontSize="22" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding VersionUpdates.CurrentServerType}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Target server version" Style="{StaticResource SettingsSubtext}"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ComboBox ItemsSource="{Binding VersionUpdates.TargetVersions}"
                                                                  SelectedItem="{Binding VersionUpdates.SelectedTargetVersion, Mode=TwoWay}"
                                                                  DisplayMemberPath="Id"
                                                                  IsEnabled="{Binding VersionUpdates.HasTargetVersions}"
                                                                  MinHeight="34"/>
                                                        <ui:Button Grid.Column="1"
                                                                   Icon="{ui:SymbolIcon ArrowClockwise24}"
                                                                   Appearance="Secondary"
                                                                   Command="{Binding VersionUpdates.LoadTargetVersionsCommand}"
                                                                   Margin="8,0,0,0"
                                                                   ToolTip="Refresh available versions"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding VersionUpdates.TargetVersionStatusText}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Text="Required Java version change" Style="{StaticResource SettingsSubtext}" Margin="0,20,0,4"/>
                                            <TextBlock Text="{Binding VersionUpdates.RequiredJavaVersionChange}" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                            <TextBlock Text="Addon update mode" Style="{StaticResource SettingsSubtext}" Margin="0,20,0,8"/>
                                            <ComboBox ItemsSource="{Binding VersionUpdates.UpdateModes}"
                                                      SelectedItem="{Binding VersionUpdates.SelectedUpdateMode, Mode=TwoWay}"
                                                      DisplayMemberPath="DisplayName"
                                                      MinHeight="34"/>
                                        </StackPanel>
                                    </ui:Card>

                                    <ui:Card Padding="24" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Addon Migration Summary" Style="{StaticResource SettingsHeader}" FontSize="16"/>
                                            <UniformGrid Columns="2" Margin="0,8,0,0">
                                                <StackPanel Margin="0,0,16,12">
                                                    <TextBlock Text="Tracked addons" Style="{StaticResource SettingsSubtext}"/>
                                                    <TextBlock Text="{Binding VersionUpdates.TrackedAddonCount}" FontSize="20" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,16,12">
                                                    <TextBlock Text="Manual/untracked addons" Style="{StaticResource SettingsSubtext}"/>
                                                    <TextBlock Text="{Binding VersionUpdates.ManualUntrackedAddonCount}" FontSize="20" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,16,12">
                                                    <TextBlock Text="Compatible updates" Style="{StaticResource SettingsSubtext}"/>
                                                    <TextBlock Text="{Binding VersionUpdates.CompatibleUpdateCount}" FontSize="20" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,16,12">
                                                    <TextBlock Text="Incompatible addons" Style="{StaticResource SettingsSubtext}"/>
                                                    <TextBlock Text="{Binding VersionUpdates.IncompatibleAddonCount}" FontSize="20" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,16,12">
                                                    <TextBlock Text="Dependency additions" Style="{StaticResource SettingsSubtext}"/>
                                                    <TextBlock Text="{Binding VersionUpdates.DependencyAdditionCount}" FontSize="20" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,16,12">
                                                    <TextBlock Text="Rollback availability" Style="{StaticResource SettingsSubtext}"/>
                                                    <TextBlock Text="{Binding VersionUpdates.RollbackAvailabilityText}" FontSize="12" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </UniformGrid>
                                        </StackPanel>
                                    </ui:Card>

                                    <ui:Card Padding="24" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Changelog Preview" Style="{StaticResource SettingsHeader}" FontSize="16"/>
                                            <TextBlock Text="{Binding VersionUpdates.ChangelogPreview}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </ui:Card>

                                    <ui:Card Padding="24" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Warnings" Style="{StaticResource SettingsHeader}" FontSize="16"/>
                                            <ItemsControl ItemsSource="{Binding VersionUpdates.Warnings}" Margin="0,8,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                            <ui:SymbolIcon Symbol="Warning24" Foreground="#F9E2AF" Margin="0,0,8,0"/>
                                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ui:Card>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- TAB 3: GAMEPLAY RULES -->
                        <TabItem Header="Gameplay">
                            <ScrollViewer x:Name="GameplayScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                                <StackPanel>
                                    <ui:Card Padding="24" Margin="0,0,0,16"
                                             Visibility="{Binding IsJavaSettings, Converter={StaticResource VisibleIfTrue}}">
                                        <StackPanel>
                                            <WrapPanel>
                                                <StackPanel Width="280" Margin="10,0,10,20">
                                                    <TextBlock Text="Default Gamemode:" Style="{StaticResource SettingsSubtext}"/>
                                                    <ComboBox ItemsSource="{Binding World.Gamemodes}" SelectedItem="{Binding World.Gamemode, Mode=TwoWay}" HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                                <StackPanel Width="280" Margin="10,0,10,20">
                                                    <TextBlock Text="World Difficulty:" Style="{StaticResource SettingsSubtext}"/>
                                                    <ComboBox ItemsSource="{Binding World.Difficulties}" SelectedItem="{Binding World.Difficulty, Mode=TwoWay}" HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                                <StackPanel Width="280" Margin="10,0,10,20">
                                                    <TextBlock Text="Maximum Players:" Style="{StaticResource SettingsSubtext}"/>
                                                    <ui:TextBox Text="{Binding World.MaxPlayers, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <StackPanel Width="280" Margin="10,0,10,20">
                                                    <TextBlock Text="Spawn Protection Radius:" Style="{StaticResource SettingsSubtext}"/>
                                                    <ui:TextBox Text="{Binding World.SpawnProtection, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                            </WrapPanel>

                                            <!-- Render & Simulation Distance Sliders -->
                                            <TextBlock Text="Render &amp; Simulation Distance" Style="{StaticResource SettingsHeader}" FontSize="15" Margin="10,4,0,2"/>
                                            <TextBlock Text="Controls how far (in chunks) players can see and how far the server actively simulates game mechanics."
                                                       Style="{StaticResource SettingsSubtext}" Margin="10,0,0,12"/>
                                            <Grid Margin="10,0,10,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="View Distance:" VerticalAlignment="Center" FontSize="13" Margin="0,0,12,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                    <Run Text="{Binding World.ViewDistance, Mode=OneWay}"/><Run Text=" chunks"/>
                                                </TextBlock>
                                                <Slider Grid.Column="2" Value="{Binding World.ViewDistance}" Minimum="3" Maximum="32"
                                                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="8,0"/>
                                                <TextBlock Grid.Column="3" Text="32" VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                            </Grid>
                                            <Grid Margin="10,0,10,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Simulation Distance:" VerticalAlignment="Center" FontSize="13" Margin="0,0,12,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                    <Run Text="{Binding World.SimulationDistance, Mode=OneWay}"/><Run Text=" chunks"/>
                                                </TextBlock>
                                                <Slider Grid.Column="2" Value="{Binding World.SimulationDistance}" Minimum="3" Maximum="32"
                                                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="8,0"/>
                                                <TextBlock Grid.Column="3" Text="32" VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                            </Grid>

                                            <Separator Margin="0,10,0,20" Background="#313244"/>

                                            <WrapPanel>
                                                <StackPanel Width="400" Margin="10">
                                                    <ui:ToggleSwitch IsChecked="{Binding World.OnlineMode}" Content="Online Mode (Identity Auth)" />
                                                    <ui:ToggleSwitch IsChecked="{Binding World.Pvp}" Content="Enable PvP Damage" />
                                                    <ui:ToggleSwitch IsChecked="{Binding World.WhiteList}" Content="Enable Whitelist" />
                                                </StackPanel>
                                                <StackPanel Width="400" Margin="10">
                                                    <ui:ToggleSwitch IsChecked="{Binding World.AllowCommandBlock}" Content="Enable Command Blocks" />
                                                    <ui:ToggleSwitch IsChecked="{Binding World.AllowFlight}" Content="Allow Cheat Flight" />
                                                    <ui:ToggleSwitch IsChecked="{Binding World.AllowNether}" Content="Allow Dimension: Nether" />
                                                </StackPanel>
                                            </WrapPanel>
                                        </StackPanel>
                                    </ui:Card>

                                    <ui:Card Padding="24" Margin="0,0,0,16"
                                             Visibility="{Binding IsBedrockSettings, Converter={StaticResource VisibleIfTrue}}">
                                        <StackPanel>
                                            <TextBlock Text="Bedrock Rules" Style="{StaticResource SettingsHeader}" FontSize="18"/>
                                            <WrapPanel Margin="0,10,0,8">
                                                <StackPanel Width="280" Margin="10,0,10,20">
                                                    <TextBlock Text="Default Gamemode:" Style="{StaticResource SettingsSubtext}"/>
                                                    <ComboBox ItemsSource="{Binding World.Gamemodes}" SelectedItem="{Binding World.Gamemode, Mode=TwoWay}" HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                                <StackPanel Width="280" Margin="10,0,10,20">
                                                    <TextBlock Text="Difficulty:" Style="{StaticResource SettingsSubtext}"/>
                                                    <ComboBox ItemsSource="{Binding World.Difficulties}" SelectedItem="{Binding World.Difficulty, Mode=TwoWay}" HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                                <StackPanel Width="280" Margin="10,0,10,20">
                                                    <TextBlock Text="Maximum Players:" Style="{StaticResource SettingsSubtext}"/>
                                                    <ui:TextBox Text="{Binding World.MaxPlayers, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <StackPanel Width="280" Margin="10,0,10,20">
                                                    <TextBlock Text="Tick Distance:" Style="{StaticResource SettingsSubtext}"/>
                                                    <ui:TextBox Text="{Binding Bedrock.TickDistance, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <StackPanel Width="280" Margin="10,0,10,20">
                                                    <TextBlock Text="Default Permission:" Style="{StaticResource SettingsSubtext}"/>
                                                    <ComboBox ItemsSource="{Binding Bedrock.PermissionLevels}" SelectedItem="{Binding Bedrock.DefaultPlayerPermissionLevel, Mode=TwoWay}" HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                                <StackPanel Width="280" Margin="10,0,10,20">
                                                    <TextBlock Text="IPv6 Port:" Style="{StaticResource SettingsSubtext}"/>
                                                    <ui:TextBox Text="{Binding Bedrock.ServerPortV6, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                            </WrapPanel>

                                            <!-- Bedrock Render Distance Slider -->
                                            <TextBlock Text="Render Distance" Style="{StaticResource SettingsHeader}" FontSize="15" Margin="10,4,0,2"/>
                                            <TextBlock Text="The maximum distance in chunks that the server will send world data to players. Higher values increase network and memory usage."
                                                       Style="{StaticResource SettingsSubtext}" Margin="10,0,0,12" TextWrapping="Wrap"/>
                                            <Grid Margin="10,0,10,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="View Distance:" VerticalAlignment="Center" FontSize="13" Margin="0,0,12,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                    <Run Text="{Binding Bedrock.ViewDistance, Mode=OneWay}"/><Run Text=" chunks"/>
                                                </TextBlock>
                                                <Slider Grid.Column="2" Value="{Binding Bedrock.ViewDistance}" Minimum="5" Maximum="96"
                                                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="8,0"/>
                                                <TextBlock Grid.Column="3" Text="96" VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                            </Grid>

                                            <Separator Margin="0,10,0,20" Background="#313244"/>

                                            <WrapPanel>
                                                <StackPanel Width="400" Margin="10">
                                                    <ui:ToggleSwitch IsChecked="{Binding World.OnlineMode}" Content="Online Mode" />
                                                    <ui:ToggleSwitch IsChecked="{Binding World.Pvp}" Content="Enable PvP Damage" />
                                                    <ui:ToggleSwitch IsChecked="{Binding World.WhiteList}" Content="Enable Whitelist" />
                                                </StackPanel>
                                                <StackPanel Width="400" Margin="10">
                                                    <ui:ToggleSwitch IsChecked="{Binding Bedrock.AllowCheats}" Content="Allow Cheats" />
                                                    <ui:ToggleSwitch IsChecked="{Binding Bedrock.TexturepackRequired}" Content="Require Resource Packs" />
                                                    <ui:ToggleSwitch IsChecked="{Binding Bedrock.ForceGamemode}" Content="Force Default Gamemode" />
                                                </StackPanel>
                                            </WrapPanel>
                                        </StackPanel>
                                    </ui:Card>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- TAB 3: WORLD & FILES -->
                        <TabItem Header="World">
                            <ScrollViewer x:Name="WorldScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                                <StackPanel>
                                    <ui:Card Padding="32" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="World Instance Management" Style="{StaticResource SettingsHeader}" FontSize="18"/>
                                            <TextBlock Text="{Binding World.WorldStatusText}" Foreground="#A6E3A1" FontWeight="SemiBold" Margin="0,5,0,2"/>
                                            <TextBlock Text="{Binding World.WorldSizeText}" Style="{StaticResource SettingsSubtext}" Margin="0,0,0,25"/>

                                            <TextBlock Text="World Generation Seed:" Style="{StaticResource SettingsHeader}"/>
                                            <ui:TextBox Text="{Binding World.Seed, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Leave empty for random" Margin="0,0,0,15"/>

                                            <StackPanel Visibility="{Binding SupportsJavaWorldGenerator, Converter={StaticResource VisibleIfTrue}}">
                                                <TextBlock Text="World Generator Type:" Style="{StaticResource SettingsHeader}"/>
                                                <ComboBox ItemsSource="{Binding World.LevelTypes}" SelectedItem="{Binding World.LevelType, Mode=TwoWay}" Margin="0,0,0,30" HorizontalAlignment="Left" Width="300"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal">
                                                <ui:Button Content="{Binding World.ImportWorldButtonText}" Command="{Binding World.UploadWorldCommand}" Appearance="Primary" Margin="0,0,12,0" Icon="{ui:SymbolIcon ArrowUpload24}"/>
                                                <ui:Button Content="Wipe World Data" Command="{Binding World.DeleteWorldCommand}" Appearance="Danger" Margin="0,0,12,0" Icon="{ui:SymbolIcon Delete24}"/>
                                                <ui:Button Content="Browse Maps" Command="{Binding World.BrowseMapsCommand}" Appearance="Secondary" Icon="{ui:SymbolIcon Globe24}" ToolTip="Find community maps on minecraftmaps.com" Visibility="{Binding IsJavaSettings, Converter={StaticResource VisibleIfTrue}}"/>
                                            </StackPanel>
                                            <TextBlock Text="Download a map from the web, then import it using the button above."
                                                       Style="{StaticResource SettingsSubtext}" Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </ui:Card>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- TAB 4: ADDONS -->
                        <TabItem Header="Addons">
                            <ScrollViewer x:Name="AddonsScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                                <StackPanel>
                                    <!-- Search and Sort Control Bar -->
                                    <Grid Margin="4,0,4,16" Visibility="{Binding Addons.ShowVanillaWarning, Converter={StaticResource InvertedVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="220"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Search Box -->
                                        <ui:TextBox Text="{Binding Addons.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                    PlaceholderText="Search plugins and mods..."
                                                    Icon="{ui:SymbolIcon Search20}"
                                                    Margin="0,0,12,0"
                                                    VerticalAlignment="Center"/>
                                        
                                        <!-- Sort Dropdown -->
                                        <Grid Grid.Column="1" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Sort:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <ComboBox Grid.Column="1" 
                                                      ItemsSource="{Binding Addons.SortOptions}" 
                                                      SelectedItem="{Binding Addons.SelectedSortOption}" 
                                                      VerticalAlignment="Center"/>
                                        </Grid>
                                    </Grid>

                                    <!-- Warning Summary Banner -->
                                    <ui:Card Visibility="{Binding Addons.HasWarningsBanner, Converter={StaticResource VisibleIfTrue}}"
                                             Background="#2D1E24" BorderBrush="#F38BA8" BorderThickness="1"
                                             Margin="4,0,4,16" Padding="12">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Warning24" Foreground="#F38BA8" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="#F38BA8">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} suspicious or client-only add-on(s) detected. Server might crash or ignore them.">
                                                        <Binding Path="Addons.WarningsCount"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </ui:Card>

                                    <!-- Vanilla Empty State -->
                                    <ui:Card Padding="32" Margin="0,0,0,16"
                                             Visibility="{Binding Addons.ShowVanillaWarning, Converter={StaticResource VisibleIfTrue}}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <ui:SymbolIcon Symbol="Prohibited24" FontSize="36" Foreground="#F38BA8" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                            <TextBlock Text="Vanilla doesn't support mods, plugins, and addons." FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="To install plugins or mods, please change your server type to Paper, Fabric, Forge, or NeoForge."
                                                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,6,0,0" MaxWidth="360"/>
                                        </StackPanel>
                                    </ui:Card>

                                    <TextBlock Text="Server Plugins" Style="{StaticResource SettingsHeader}" Margin="4,0,0,12"
                                               Visibility="{Binding Addons.SupportsPlugins, Converter={StaticResource VisibleIfTrue}}"/>
                                    <ui:Card Margin="0,0,0,16" Padding="20"
                                             Visibility="{Binding Addons.SupportsPlugins, Converter={StaticResource VisibleIfTrue}}">
                                        <StackPanel>
                                            <TextBlock Visibility="{Binding Addons.IsPocketmine, Converter={StaticResource VisibleIfTrue}}"
                                                       Text="ℹ PocketMine plugins are .phar files. Use the Poggit marketplace button to browse and install them." Foreground="#89B4FA" Margin="0,0,0,10" FontSize="12" TextWrapping="Wrap"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:Button Content="Local File" Command="{Binding Addons.AddPluginCommand}" Appearance="Secondary" Margin="0,0,12,0" Icon="{ui:SymbolIcon Add20}"/>
                                                    <ui:Button Content="Plugin Marketplace" Command="{Binding Addons.BrowseModrinthPluginsCommand}" Appearance="Primary" Icon="{ui:SymbolIcon Globe20}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" Margin="0,0,8,0">
                                                        <ui:ProgressRing.Style>
                                                            <Style TargetType="ui:ProgressRing">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Addons.IsUpdatingAll}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:ProgressRing.Style>
                                                    </ui:ProgressRing>
                                                    <ui:Button Content="Update All" Appearance="Info"
                                                               Command="{Binding Addons.UpdateAllPluginsCommand}"
                                                               Icon="{ui:SymbolIcon ArrowSync20}"
                                                               ToolTip="Check all installed plugins for updates"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="{Binding Addons.UpdateAllStatusText}" FontSize="11" Foreground="#89B4FA" Margin="0,8,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Addons.IsUpdatingAll}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </ui:Card>
                                    <ItemsControl ItemsSource="{Binding Addons.Plugins}" Margin="0,0,0,24">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ui:Card Margin="0,0,0,10" Padding="16,12" Tag="{Binding DataContext.Addons, RelativeSource={RelativeSource AncestorType=Page}}">
                                                    <ui:Card.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Open Folder" 
                                                                      Command="{Binding Path=PlacementTarget.Tag.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding Path}">
                                                                <MenuItem.Icon>
                                                                    <ui:SymbolIcon Symbol="FolderOpen20"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </ui:Card.ContextMenu>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <!-- Icon -->
                                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="6" Background="{DynamicResource ControlAltFillColorTertiaryBrush}" Margin="0,0,16,0" VerticalAlignment="Center" ClipToBounds="True">
                                                            <Image Source="{Binding Icon}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Border>
                                                        
                                                        <!-- Info -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                                            
                                                            <!-- Subtitle: Filename · API version · Source -->
                                                            <WrapPanel Margin="0,2,0,0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding FileName}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                                <TextBlock Text=" • " FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                                <TextBlock Text="{Binding ApiVersion, StringFormat=API: {0}}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                                <TextBlock Text=" • " FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                                <TextBlock Text="{Binding SourceLabel}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                            </WrapPanel>
                                                            
                                                            <!-- Warning message if any -->
                                                            <TextBlock Visibility="{Binding HasWarnings, Converter={StaticResource VisibleIfTrue}}"
                                                                       Text="{Binding WarningText}" FontSize="11" Foreground="#F38BA8" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                            
                                                            <!-- Update status -->
                                                            <TextBlock Text="{Binding UpdateStatusText}" FontSize="11" Foreground="#89B4FA" Margin="0,4,0,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        
                                                        <!-- Action buttons -->
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <ui:ProgressRing IsIndeterminate="True" Width="18" Height="18" Margin="0,0,8,0">
                                                                <ui:ProgressRing.Style>
                                                                    <Style TargetType="ui:ProgressRing">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ui:ProgressRing.Style>
                                                            </ui:ProgressRing>
                                                            <ui:Button Content="Update" Appearance="Info" Margin="0,0,8,0" VerticalAlignment="Center"
                                                                       Command="{Binding DataContext.Addons.UpdatePluginCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                       CommandParameter="{Binding}"
                                                                       IsEnabled="{Binding IsUpdating, Converter={StaticResource InvertedBooleanConverter}}"
                                                                       Icon="{ui:SymbolIcon ArrowSync20}"
                                                                       ToolTip="Check for updates from the marketplace"/>
                                                            <ui:Button Content="Delete" Appearance="Danger" Command="{Binding DataContext.Addons.DeletePluginCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding Path}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </ui:Card>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Server Mods — hidden for PocketMine (not applicable) -->
                                    <TextBlock Text="Server Mods" Style="{StaticResource SettingsHeader}" Margin="4,20,0,12"
                                               Visibility="{Binding Addons.SupportsMods, Converter={StaticResource VisibleIfTrue}}"/>
                                    <ui:Card Margin="0,0,0,16" Padding="20"
                                             Visibility="{Binding Addons.SupportsMods, Converter={StaticResource VisibleIfTrue}}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:Button Content="Add Mod JAR" Command="{Binding Addons.AddModCommand}" Appearance="Secondary" Margin="0,0,12,0" Icon="{ui:SymbolIcon Add20}"/>
                                                    <ui:Button Content="Browse Marketplace" Command="{Binding Addons.BrowseModrinthModsCommand}" Appearance="Primary" Margin="0,0,12,0" Icon="{ui:SymbolIcon Globe20}"/>
                                                    <ui:Button Content="Import Pack" Command="{Binding Addons.ImportModpackCommand}" Appearance="Secondary" Icon="{ui:SymbolIcon FolderZip20}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" Margin="0,0,8,0">
                                                        <ui:ProgressRing.Style>
                                                            <Style TargetType="ui:ProgressRing">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Addons.IsUpdatingAll}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:ProgressRing.Style>
                                                    </ui:ProgressRing>
                                                    <ui:Button Content="Update All" Appearance="Info"
                                                               Command="{Binding Addons.UpdateAllModsCommand}"
                                                               Icon="{ui:SymbolIcon ArrowSync20}"
                                                               ToolTip="Check all installed mods for updates"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="{Binding Addons.UpdateAllStatusText}" FontSize="11" Foreground="#89B4FA" Margin="0,8,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Addons.IsUpdatingAll}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </ui:Card>
                                    <ItemsControl ItemsSource="{Binding Addons.Mods}"
                                                   Visibility="{Binding Addons.SupportsMods, Converter={StaticResource VisibleIfTrue}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ui:Card Margin="0,0,0,10" Padding="16,12" Tag="{Binding DataContext.Addons, RelativeSource={RelativeSource AncestorType=Page}}">
                                                    <ui:Card.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Command="{Binding Path=PlacementTarget.Tag.ToggleModActiveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding Path}">
                                                                <MenuItem.Style>
                                                                    <Style TargetType="MenuItem">
                                                                        <Setter Property="Header" Value="Disable Mod"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                                                                                <Setter Property="Header" Value="Enable Mod"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </MenuItem.Style>
                                                                <MenuItem.Icon>
                                                                    <ui:SymbolIcon Symbol="Power20"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="Open Folder" 
                                                                      Command="{Binding Path=PlacementTarget.Tag.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding Path}">
                                                                <MenuItem.Icon>
                                                                    <ui:SymbolIcon Symbol="FolderOpen20"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </ui:Card.ContextMenu>
                                                    <Grid>
                                                        <Grid.Style>
                                                            <Style TargetType="Grid">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                                                                        <Setter Property="Opacity" Value="0.6"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Grid.Style>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Icon -->
                                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="6" Background="{DynamicResource ControlAltFillColorTertiaryBrush}" Margin="0,0,16,0" VerticalAlignment="Center" ClipToBounds="True">
                                                            <Image Source="{Binding Icon}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Border>

                                                        <!-- Info -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                                                
                                                                <!-- Disabled badge -->
                                                                <Border Visibility="{Binding IsDisabled, Converter={StaticResource VisibleIfTrue}}"
                                                                        Background="#4F4F4F" CornerRadius="4" Margin="8,0,0,0" Padding="6,2" VerticalAlignment="Center">
                                                                    <TextBlock Text="Disabled" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                                </Border>

                                                                <!-- Warning Icon -->
                                                                <ui:SymbolIcon Symbol="Warning16" Foreground="#F38BA8" Margin="8,0,0,0" VerticalAlignment="Center"
                                                                               Visibility="{Binding HasWarnings, Converter={StaticResource VisibleIfTrue}}"
                                                                               ToolTip="{Binding WarningText}"/>
                                                            </StackPanel>

                                                            <!-- Subtitle: Filename · Loader · Version · Source -->
                                                            <WrapPanel Margin="0,4,0,0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding FileName}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                                <TextBlock Text=" • " FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                                
                                                                <Border Background="{DynamicResource ControlAltFillColorTertiaryBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                                    <TextBlock Text="{Binding LoaderType}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                                </Border>
                                                                
                                                                <StackPanel Orientation="Horizontal" Visibility="{Binding HasVersion, Converter={StaticResource VisibleIfTrue}}">
                                                                    <TextBlock Text="v" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                                    <TextBlock Text="{Binding Version}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                                    <TextBlock Text=" • " FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                                </StackPanel>
                                                                
                                                                <Border Background="{DynamicResource ControlAltFillColorTertiaryBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                                    <TextBlock Text="{Binding SourceLabel}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                                </Border>
                                                                
                                                                <Border Background="{Binding SideBadgeBackground}" CornerRadius="4" Padding="6,2">
                                                                    <TextBlock Text="{Binding SideLabel}" FontSize="10" FontWeight="SemiBold" Foreground="{Binding SideBadgeForeground}"/>
                                                                </Border>
                                                            </WrapPanel>

                                                            <!-- Client Only warning banner -->
                                                            <Border Visibility="{Binding IsClientOnly, Converter={StaticResource VisibleIfTrue}}"
                                                                    Background="#2D1E24" BorderBrush="#F38BA8" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,6,0,0" HorizontalAlignment="Left">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <ui:SymbolIcon Symbol="Warning12" Foreground="#F38BA8" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="Client-only mod. Do not install on server unless you know what you are doing." FontSize="11" Foreground="#F38BA8" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>

                                                            <!-- Update status -->
                                                            <TextBlock Text="{Binding UpdateStatusText}" FontSize="11" Foreground="#89B4FA" Margin="0,4,0,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>

                                                        <!-- Actions -->
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <ui:ProgressRing IsIndeterminate="True" Width="18" Height="18" Margin="0,0,8,0">
                                                                <ui:ProgressRing.Style>
                                                                    <Style TargetType="ui:ProgressRing">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ui:ProgressRing.Style>
                                                            </ui:ProgressRing>
                                                            <ui:Button Content="Update" Appearance="Info" Margin="0,0,8,0" VerticalAlignment="Center"
                                                                       Command="{Binding DataContext.Addons.UpdateModCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                       CommandParameter="{Binding}"
                                                                       Icon="{ui:SymbolIcon ArrowSync20}"
                                                                       ToolTip="Check for updates from the marketplace">
                                                                <ui:Button.Style>
                                                                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                                        <Setter Property="IsEnabled" Value="True"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ui:Button.Style>
                                                            </ui:Button>
                                                            <ui:Button Content="Delete" Appearance="Danger" Command="{Binding DataContext.Addons.DeleteModCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding Path}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </ui:Card>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- BDS: Add-on import section (replaces mods for Bedrock) -->
                                    <TextBlock Text="Bedrock Add-ons" Style="{StaticResource SettingsHeader}" Margin="4,20,0,12"
                                               Visibility="{Binding Addons.SupportsBedrockAddons, Converter={StaticResource VisibleIfTrue}}"/>
                                    <ui:Card Margin="0,0,0,16" Padding="20"
                                             Visibility="{Binding Addons.SupportsBedrockAddons, Converter={StaticResource VisibleIfTrue}}">
                                        <StackPanel>
                                            <TextBlock Text="ℹ Import .mcpack or .mcaddon files. They will be automatically extracted and registered in your world's pack list."
                                                       Foreground="#89B4FA" FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:Button Content="Import Add-on (.mcpack/.mcaddon)" Command="{Binding Addons.ImportBedrockAddonCommand}" Appearance="Primary" Icon="{ui:SymbolIcon Add20}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </ui:Card>
                                    <ItemsControl ItemsSource="{Binding Addons.Mods}"
                                                  Visibility="{Binding Addons.SupportsBedrockAddons, Converter={StaticResource VisibleIfTrue}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ui:Card Margin="0,0,0,10" Padding="16,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                                            <TextBlock Text="{Binding AddonType, StringFormat=Type: {0}}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        </StackPanel>
                                                        <ui:Button Grid.Column="1" Content="Remove" Appearance="Danger" Command="{Binding DataContext.Addons.DeleteBedrockAddonCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding Path}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </ui:Card>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- TAB 5: BACKUPS -->
                        <TabItem Header="Backups">
                            <ScrollViewer x:Name="BackupsScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                                <StackPanel>

                                    <!-- HEALTH WARNINGS BANNER -->
                                    <Border Margin="0,0,0,12" Padding="16,12" CornerRadius="8"
                                            Visibility="{Binding Backups.HasHealthWarning, Converter={StaticResource VisibleIfTrue}}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#22F9A825"/>
                                                <Setter Property="BorderBrush" Value="#44F9A825"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Backups.HasHealthCritical}" Value="True">
                                                        <Setter Property="Background" Value="#22F38BA8"/>
                                                        <Setter Property="BorderBrush" Value="#44F38BA8"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Top">
                                                <ui:SymbolIcon.Style>
                                                    <Style TargetType="ui:SymbolIcon">
                                                        <Setter Property="Symbol" Value="Warning24"/>
                                                        <Setter Property="Foreground" Value="#F9A825"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Backups.HasHealthCritical}" Value="True">
                                                                <Setter Property="Symbol" Value="ErrorCircle24"/>
                                                                <Setter Property="Foreground" Value="#F38BA8"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:SymbolIcon.Style>
                                            </ui:SymbolIcon>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Backup Health Warning"/>
                                                            <Setter Property="Foreground" Value="#F9A825"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Backups.HasHealthCritical}" Value="True">
                                                                    <Setter Property="Foreground" Value="#F38BA8"/>
                                                                    <Setter Property="Text" Value="Backup Health Alert"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Backups.HealthWarningText}" TextWrapping="Wrap" FontSize="12"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- BACKUP STATS SUMMARY -->
                                    <Border Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                        <UniformGrid Columns="3">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="TOTAL SIZE" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Backups.TotalBackupsSizeText, FallbackValue='—'}" FontSize="13" FontWeight="Bold"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="LAST BACKUP" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Backups.LastBackupTimeText, FallbackValue='Never'}" FontSize="13" FontWeight="Bold"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="DISK SPACE" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Backups.DiskSpaceText, FallbackValue='—'}" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Backups.ShowDiskWarning}" Value="True">
                                                                    <Setter Property="Foreground" Value="#F38BA8"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </UniformGrid>
                                    </Border>

                                    <!-- LOCAL BACKUP LOCATION -->
                                    <ui:Card Padding="24" Margin="0,0,0,20">
                                        <StackPanel>
                                            <TextBlock Text="Local Backup Destination" Style="{StaticResource SettingsHeader}"/>
                                            <TextBlock Text="Choose where to keep local world backups. Leave blank to store backups inside the server directory." Style="{StaticResource SettingsSubtext}" Margin="0,0,0,12" TextWrapping="Wrap"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ui:TextBox Grid.Column="0" Text="{Binding Backups.CustomBackupDirectory, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Default: [Server Folder]\backups" IsReadOnly="True" Margin="0,0,8,0"/>
                                                <ui:Button Grid.Column="1" Content="Browse" Command="{Binding Backups.BrowseBackupDirCommand}" Margin="0,0,8,0" Width="100"/>
                                                <ui:Button Grid.Column="2" Content="Reset" Command="{Binding Backups.ResetBackupDirCommand}" Width="80"/>
                                            </Grid>
                                        </StackPanel>
                                    </ui:Card>

                                    <!-- AUTOMATED DATA RETENTION CONFIG -->
                                    <ui:Card Padding="24" Margin="0,0,0,20">
                                        <StackPanel>
                                            <TextBlock Text="Automated Data Retention" Style="{StaticResource SettingsHeader}"/>
                                            <WrapPanel Margin="0,10,0,20">
                                                <StackPanel Width="230" Margin="0,0,20,10">
                                                    <TextBlock Text="Interval (Hours):" Style="{StaticResource SettingsSubtext}"/>
                                                    <ui:TextBox Text="{Binding Backups.BackupIntervalHours, Mode=TwoWay}" PlaceholderText="0 = Manual Only"/>
                                                </StackPanel>
                                                <StackPanel Width="230" Margin="0,0,0,10">
                                                    <TextBlock Text="Max Archives Kept:" Style="{StaticResource SettingsSubtext}"/>
                                                    <ui:TextBox Text="{Binding Backups.MaxBackupsToKeep, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </WrapPanel>
                                            <ui:Button Content="Create Backup Now" Command="{Binding Backups.CreateBackupCommand}" Appearance="Primary" Icon="{ui:SymbolIcon Save20}" Margin="0,5,0,0"/>
                                            <StackPanel Visibility="{Binding Backups.IsBackingUp, Converter={StaticResource VisibleIfTrue}}" Margin="0,15,0,0">
                                                <ProgressBar IsIndeterminate="True" Height="4"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </ui:Card>

                                    <ui:Card Padding="24" Margin="0,0,0,20"
                                             Visibility="{Binding CloudBackups.IsCloudBackupsEnabled, Converter={StaticResource VisibleIfTrue}}">
                                        <StackPanel DataContext="{Binding CloudBackups}">
                                            <TextBlock Text="Cloud Off-site Sync" Style="{StaticResource SettingsHeader}"/>
                                            <TextBlock Text="Enable and configure cloud retention for this instance. Requires a connected provider in App Settings." TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,16"/>

                                            <StackPanel Visibility="{Binding IsRefreshingProviders, Converter={StaticResource VisibleIfTrue}}" Margin="0,0,0,12">
                                                <ProgressBar IsIndeterminate="True" Height="4"/>
                                                <TextBlock Text="{Binding ProviderStatusMessage}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,8,0,0"/>
                                            </StackPanel>

                                            <StackPanel Visibility="{Binding ShowNoConnectedProvidersMessage, Converter={StaticResource VisibleIfTrue}}" Margin="0,0,0,12">
                                                <TextBlock Text="{Binding ProviderStatusMessage}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <StackPanel Visibility="{Binding HasConnectedProviders, Converter={StaticResource VisibleIfTrue}}">
                                                <ItemsControl ItemsSource="{Binding Targets}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,0,0,12">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="150"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <ui:ToggleSwitch Grid.Column="0" Content="{Binding ProviderType}" IsChecked="{Binding IsEnabled, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="{Binding IsEnabled, Converter={StaticResource VisibleIfTrue}}">
                                                                    <TextBlock Text="Retention Count:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                                    <ui:TextBox Text="{Binding RetentionCount, Mode=TwoWay}" Width="80" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <Separator Margin="0,8" Opacity="0.15"/>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Remote Backups:" FontWeight="Medium" VerticalAlignment="Center"/>
                                                    <ui:Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshRemoteBackupsCommand}" Appearance="Secondary" Icon="{ui:SymbolIcon ArrowSync20}" VerticalAlignment="Center"/>
                                                </Grid>

                                                <ui:ListView ItemsSource="{Binding RemoteBackups}" Margin="0,12,0,0" MaxHeight="250" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                    <ui:ListView.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,4">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <ui:SymbolIcon Symbol="Cloud20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding FileName}" FontWeight="Bold" FontSize="13"/>
                                                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                                        <Run Text="{Binding Provider, StringFormat={}[{0}] }"/>
                                                                        <Run Text="{Binding SizeMb, StringFormat={}{0:F1} MB}"/>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <ui:Button Content="Restore" Appearance="Secondary" Command="{Binding DataContext.RestoreRemoteBackupCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Margin="0,0,8,0"/>
                                                                    <ui:Button Icon="{ui:SymbolIcon Delete20}" Appearance="Danger" Command="{Binding DataContext.DeleteRemoteBackupCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ui:ListView.ItemTemplate>
                                                </ui:ListView>
                                            </StackPanel>
                                        </StackPanel>
                                    </ui:Card>

                                    <!-- BACKUP HISTORY (Versioned Cards) -->
                                    <TextBlock Text="Backup History" Style="{StaticResource SettingsHeader}" Margin="4,0,0,12"/>
                                    <ItemsControl ItemsSource="{Binding Backups.BackupList}" Margin="0,0,0,24">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ui:Card Margin="0,0,0,10" Padding="16,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Version Badge -->
                                                        <Border Grid.Column="0" Background="#3389B4FA" CornerRadius="6" Padding="8,4" Margin="0,0,12,0"
                                                                VerticalAlignment="Top" HorizontalAlignment="Center" MinWidth="36">
                                                            <TextBlock Text="{Binding VersionText, FallbackValue='—'}" FontSize="12" FontWeight="Bold"
                                                                       Foreground="{DynamicResource SystemFillColorAttentionBrush}" HorizontalAlignment="Center"/>
                                                        </Border>

                                                        <!-- Backup Info -->
                                                        <StackPanel Grid.Column="1">
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                                                <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                                                        Visibility="{Binding HasMetadata, Converter={StaticResource VisibleIfTrue}}">
                                                                    <TextBlock Text="{Binding TriggerText}" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                                </Border>
                                                                <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="4" Padding="6,2" Margin="8,0,0,0" ToolTip="{Binding FullPath}">
                                                                    <TextBlock Text="{Binding LocationText}" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                                </Border>
                                                            </StackPanel>

                                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                <TextBlock Text="{Binding SizeText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                                <TextBlock Text="{Binding SizeDeltaText}" FontSize="11" Foreground="#A6E3A1" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                                <TextBlock Text="·" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="8,0"/>
                                                                <TextBlock Text="{Binding CreatedAtText}" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                            </StackPanel>

                                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                                                        Visibility="{Binding HasMetadata, Converter={StaticResource VisibleIfTrue}}">
                                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                                                    <Run Text="{Binding ServerType, Mode=OneWay}"/>
                                                                    <Run Text=" · "/>
                                                                    <Run Text="{Binding ServerVersion, Mode=OneWay}"/>
                                                                </TextBlock>
                                                            </StackPanel>

                                                            <!-- Label Editor -->
                                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                                                        Visibility="{Binding HasMetadata, Converter={StaticResource VisibleIfTrue}}">
                                                                <ui:TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Add a label..."
                                                                            MinHeight="30" FontSize="12" Width="280" Margin="0,0,8,0"/>
                                                                <ui:Button Icon="{ui:SymbolIcon Save16}" Appearance="Transparent" Padding="4"
                                                                           Command="{Binding DataContext.Backups.SaveLabelCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                           CommandParameter="{Binding}" ToolTip="Save label"/>
                                                            </StackPanel>

                                                            <!-- Integrity Status -->
                                                            <TextBlock Text="{Binding IntegrityStatusText}" FontSize="11" Margin="0,4,0,0"
                                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                        </StackPanel>

                                                        <!-- Action Buttons -->
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                                            <ui:Button Icon="{ui:SymbolIcon ShieldCheckmark20}" Appearance="Transparent" Padding="6"
                                                                       Command="{Binding DataContext.Backups.VerifyIntegrityCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                       CommandParameter="{Binding}" ToolTip="Verify integrity" Margin="0,0,4,0"/>
                                                            <ui:Button Content="Restore" Appearance="Secondary"
                                                                       Command="{Binding DataContext.Backups.RestoreBackupCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                       CommandParameter="{Binding FullPath}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                            <ui:Button Icon="{ui:SymbolIcon Delete20}" Appearance="Danger"
                                                                       Command="{Binding DataContext.Backups.DeleteBackupCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                       CommandParameter="{Binding FullPath}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </ui:Card>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- TAB 6: FAULT TOLERANCE -->
                        <TabItem Header="FaultTolerance">
                            <ScrollViewer x:Name="RestartScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                                <StackPanel>
                                    <ui:Card Padding="32">
                                        <StackPanel>
                                            <TextBlock Text="Auto-Restart Engine" Style="{StaticResource SettingsHeader}" FontSize="18"/>
                                            <ui:ToggleSwitch IsChecked="{Binding Advanced.EnableAutoRestart}" Content="Restart on Failure" OnContent="Enabled" OffContent="Disabled"/>

                                            <TextBlock Text="Max Failure Tolerance (Attempts):" Style="{StaticResource SettingsSubtext}" Margin="0,20,0,8"/>
                                            <ui:TextBox Text="{Binding Advanced.MaxAutoRestarts}" Width="100" HorizontalAlignment="Left"/>

                                            <TextBlock Text="Restart Cooldown (Seconds):" Style="{StaticResource SettingsSubtext}" Margin="0,20,0,8"/>
                                            <ui:TextBox Text="{Binding Advanced.AutoRestartDelay}" Width="100" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </ui:Card>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- TAB 7: ADVANCED EDITOR -->
                        <TabItem Header="Advanced">
                            <ScrollViewer x:Name="AdvancedScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                                <StackPanel>
                                    <ui:Card Padding="24" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Internal Properties (server.properties)" Style="{StaticResource SettingsHeader}"/>
                                            <TextBlock Text="Directly modify internal key-value pairs. Core properties are protected." Style="{StaticResource SettingsSubtext}" Margin="0,0,0,20"/>
                                            <ui:Button Content="Append Parameter" Command="{Binding Advanced.AddPropertyCommand}" Appearance="Secondary" Icon="{ui:SymbolIcon Add20}"/>
                                        </StackPanel>
                                    </ui:Card>

                                    <ItemsControl ItemsSource="{Binding Advanced.AdvancedProperties}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <ui:TextBox Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsCore, Converter={StaticResource InvertedBooleanConverter}}" Margin="0,0,12,0"/>
                                                    <ui:TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Delete20}" Appearance="Danger" Command="{Binding DataContext.Advanced.RemovePropertyCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Margin="12,0,0,0" Visibility="{Binding IsCore, Converter={StaticResource InvertedVisibilityConverter}}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- TAB 8: AI SUMMARIES -->
                        <TabItem Header="AISummaries">
                            <ScrollViewer x:Name="SummariesScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                                <Grid>
                                    <!-- Summary List View -->
                                    <StackPanel Visibility="{Binding Summaries.IsViewingSummary, Converter={StaticResource InvertedVisibilityConverter}}">
                                        <ui:Card Padding="24" Margin="0,0,0,16">
                                            <StackPanel>
                                                <TextBlock Text="Session Summaries" Style="{StaticResource SettingsHeader}" FontSize="18"/>
                                                <TextBlock Text="AI-generated summaries of your server play sessions. Each summary captures player activity, deaths, events, and highlights."
                                                           Style="{StaticResource SettingsSubtext}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            </StackPanel>
                                        </ui:Card>

                                        <!-- Empty State -->
                                        <ui:Card Padding="32" Margin="0,0,0,16"
                                                 Visibility="{Binding Summaries.HasSummaries, Converter={StaticResource InvertedVisibilityConverter}, FallbackValue=Visible}">
                                            <StackPanel HorizontalAlignment="Center">
                                                <ui:SymbolIcon Symbol="BrainCircuit24" FontSize="36" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                                <TextBlock Text="No summaries yet" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Text="Summaries will appear here after you stop a server session and choose to generate one."
                                                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,6,0,0" MaxWidth="360"/>
                                            </StackPanel>
                                        </ui:Card>

                                        <!-- Summaries List -->
                                        <ItemsControl ItemsSource="{Binding Summaries.Summaries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <ui:Card Margin="0,0,0,10" Padding="16,12">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                    <TextBlock Text="{Binding SessionDate}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                                                    <Border Background="#313244" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Duration}" FontSize="11" Foreground="#89B4FA"/>
                                                                    </Border>
                                                                    <Border Background="#313244" CornerRadius="4" Padding="6,2" Margin="6,0,0,0" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Provider}" FontSize="11" Foreground="#A6E3A1"/>
                                                                    </Border>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Preview}" FontSize="12"
                                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                           TextTrimming="CharacterEllipsis" MaxWidth="500" HorizontalAlignment="Left"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <ui:Button Content="View" Appearance="Secondary"
                                                                           Command="{Binding DataContext.Summaries.ViewSummaryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                           CommandParameter="{Binding}" Margin="0,0,8,0"/>
                                                                <ui:Button Icon="{ui:SymbolIcon Delete20}" Appearance="Danger"
                                                                           Command="{Binding DataContext.Summaries.DeleteSummaryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                           CommandParameter="{Binding}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </ui:Card>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- Summary Content Viewer -->
                                    <StackPanel Visibility="{Binding Summaries.IsViewingSummary, Converter={StaticResource VisibleIfTrue}}">
                                        <ui:Button Content="← Back to Summaries" Appearance="Transparent"
                                                   Command="{Binding Summaries.CloseSummaryCommand}" Margin="0,0,0,12"/>
                                        <ui:Card Padding="16" MinHeight="400">
                                            <intel:NativeMarkdownViewer Markdown="{Binding Summaries.SummaryContent, Mode=OneWay}" />
                                        </ui:Card>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </DockPanel>
    </Grid>
</Page>
