<Page x:Class="PocketMC.Desktop.Features.Shell.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="About">

    <Grid Margin="28,20,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <ui:TextBlock FontTypography="Title" Text="About PocketMC" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock x:Name="TxtVersion" Text="Version 1.0.0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13"/>
        </StackPanel>

        <ScrollViewer x:Name="AboutScrollViewer"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      PanningMode="VerticalOnly"
                      Padding="0,0,16,0">
            <StackPanel>
                <ui:Card Padding="24" VerticalAlignment="Top" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- App Logo -->
                    <Border Grid.Column="0"
                            Width="120" Height="120"
                            CornerRadius="16"
                            Margin="0,0,24,0"
                            VerticalAlignment="Center"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True">
                        <Border.Clip>
                            <RectangleGeometry Rect="0,0,120,120" RadiusX="16" RadiusY="16"/>
                        </Border.Clip>
                        <Image Source="pack://application:,,,/Assets/logo_highres.png"
                               Stretch="UniformToFill"
                               UseLayoutRounding="True"
                               SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="Fant"
                               RenderOptions.EdgeMode="Aliased"/>
                    </Border>

                    <!-- Info Content -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="PocketMC Desktop" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="A modern native desktop application for managing Minecraft servers, proxies, modpacks, and more." Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <TextBlock Text="Repository" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Contributions, issues, and feature requests are welcome on GitHub!" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Content="GitHub" Appearance="Secondary" Click="OpenGitHub_Click" Icon="{ui:SymbolIcon Code24}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- COMMUNITY SECTION -->
            <ui:CardExpander IsExpanded="True" Icon="{ui:SymbolIcon People24}">
                <ui:CardExpander.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Community" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Join our Discord server to get help, share tips, and connect with other PocketMC users." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </ui:CardExpander.Header>

                <StackPanel Margin="16,8,16,16">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ui:Button Content="Join Discord" Appearance="Primary" Click="OpenDiscord_Click"/>
                        <ui:Button Content="Copy Invite" Appearance="Secondary" Margin="8,0,0,0" Click="CopyDiscordInvite_Click"/>
                        <ui:Button Content="YouTube" Appearance="Secondary" Margin="8,0,0,0" Click="OpenYouTube_Click" Icon="{ui:SymbolIcon Video24}"/>
                        <ui:Button Content="Reddit" Appearance="Secondary" Margin="8,0,0,0" Click="OpenReddit_Click" Icon="{ui:SymbolIcon Chat24}"/>
                    </StackPanel>
                </StackPanel>
            </ui:CardExpander>

            <!-- FEEDBACK SECTION -->
            <ui:CardExpander IsExpanded="True" Icon="{ui:SymbolIcon Bug24}" Margin="0,12,0,0">
                <ui:CardExpander.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Feedback &amp; Bug Reports" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Help us improve PocketMC by reporting bugs, submitting feedback, or suggesting new features." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </ui:CardExpander.Header>

                <StackPanel Margin="16,8,16,16">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ui:Button Content="Submit Feedback / Report Bug" Appearance="Primary" Click="OpenFeedbackForm_Click" Icon="{ui:SymbolIcon Open20}"/>
                    </StackPanel>
                </StackPanel>
            </ui:CardExpander>

            <!-- SUPPORT & DONATION SECTION -->
            <ui:CardExpander IsExpanded="True" Icon="{ui:SymbolIcon Heart24}" Margin="0,12,0,0">
                <ui:CardExpander.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Support &amp; Donation" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Support the development of PocketMC! If you love this project and find it useful, consider buying us a coffee." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </ui:CardExpander.Header>

                <StackPanel Margin="16,8,16,16">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ui:Button Content="Buy Me a Coffee" Appearance="Primary" Click="OpenDonationPage_Click" Icon="{ui:SymbolIcon Heart20}"/>
                    </StackPanel>
                </StackPanel>
            </ui:CardExpander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
