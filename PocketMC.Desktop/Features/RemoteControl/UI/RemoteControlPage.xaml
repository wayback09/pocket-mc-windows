<Page x:Class="PocketMC.Desktop.Features.RemoteControl.UI.RemoteControlPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="RemoteControlPage">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <BooleanToVisibilityConverter x:Key="InverseBoolToVis" /> <!-- Note: We actually need a custom converter here if we want inverse, or we can just bind to a new property IsDiscordNotLinked -->
    </Page.Resources>

    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Remote Control"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                   Margin="24,24,24,16" />

        <ScrollViewer x:Name="RemoteControlScrollViewer"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      PanningMode="VerticalOnly"
                      Padding="24,0,24,24">
            <StackPanel>
                <ui:Card>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Enable Remote Control" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Starts a local web dashboard secured by paired device tokens."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleRemoteControlEnabled"
                                             Grid.Column="1"
                                             VerticalAlignment="Center"
                                             IsChecked="{Binding IsEnabled}"/>
                        </Grid>

                        <StackPanel Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}">
                            <Separator Margin="0,16" Opacity="0.15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Port" FontSize="14" FontWeight="Medium"/>
                                <ui:TextBox x:Name="RemotePortInput" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="25580" Margin="0,8,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Access Mode" FontSize="14" FontWeight="Medium"/>
                                <ComboBox x:Name="RemoteAccessModeCombo"
                                          ItemsSource="{Binding AccessModes}"
                                          SelectedValue="{Binding AccessMode}"
                                          SelectedValuePath="Mode"
                                          DisplayMemberPath="Label"
                                          Margin="0,8,0,0"
                                          MaxWidth="300"
                                          HorizontalAlignment="Left">
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Cloudflare Quick Tunnel creates a temporary public URL. Anyone with the URL can reach the login/pairing page. Keep pairing disabled unless you are actively pairing a device."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12"
                                   Margin="0,12,0,0"/>
                        <TextBlock Text="PlayIt HTTPS tunnels require PlayIt Premium. Stop Remote Link disables the dedicated PocketMC Remote Control tunnel."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12"
                                   Margin="0,8,0,0"/>



                        <Grid Margin="0,16,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Public Tunnel IP Card -->
                            <Border Grid.Row="0" Visibility="{Binding IsPublicUrlCardVisible, Converter={StaticResource BoolToVis}}"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6" Padding="12,10" Margin="0,0,0,8"
                                    HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <ui:SymbolIcon Grid.Row="0" Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" Symbol="Desktop24">
                                        <ui:SymbolIcon.Style>
                                            <Style TargetType="ui:SymbolIcon">
                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLoadingPublicUrl}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HasPublicUrlError}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:SymbolIcon.Style>
                                    </ui:SymbolIcon>

                                    <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding PublicUrlProviderName, StringFormat='{}{0} Public URL'}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontWeight="SemiBold"/>
                                        <Grid Margin="0,2,0,0">
                                            <TextBlock Text="{Binding PublicUrl}" FontSize="14" Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" Visibility="{Binding HasPublicUrl, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="Starting tunnel..." FontSize="14" Foreground="{DynamicResource TextFillColorDisabledBrush}" Visibility="{Binding IsLoadingPublicUrl, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="{Binding PublicUrlErrorText}" FontSize="14" Foreground="{DynamicResource SystemFillColorCriticalBrush}" TextWrapping="Wrap" Visibility="{Binding HasPublicUrlError, Converter={StaticResource BoolToVis}}"/>
                                        </Grid>
                                    </StackPanel>

                                    <Grid Grid.Row="0" Grid.Column="2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Visibility="{Binding HasPublicUrl, Converter={StaticResource BoolToVis}}">
                                            <ui:Button Appearance="Secondary" Content="Copy URL" Icon="{ui:SymbolIcon Copy16}" Command="{Binding CopyPublicUrlCommand}"/>
                                            <ui:Button Appearance="Secondary" Content="QR Code" Icon="{ui:SymbolIcon QrCode24}" Command="{Binding TogglePublicQrCommand}" Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" Margin="12,0,12,0" Visibility="{Binding IsLoadingPublicUrl, Converter={StaticResource BoolToVis}}"/>
                                        <ui:SymbolIcon Symbol="ErrorCircle24" Foreground="{DynamicResource SystemFillColorCriticalBrush}" Margin="12,0,12,0" Visibility="{Binding HasPublicUrlError, Converter={StaticResource BoolToVis}}"/>
                                    </Grid>

                                    <!-- QR Code Area -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Visibility="{Binding IsPublicQrVisible, Converter={StaticResource BoolToVis}}" HorizontalAlignment="Center" Margin="0,12,0,4">
                                        <Border Background="White" Padding="8" CornerRadius="4" BorderThickness="1" BorderBrush="#E0E0E0" HorizontalAlignment="Center">
                                            <Image Source="{Binding PublicQrImage}" Width="150" Height="150" Stretch="Uniform"/>
                                        </Border>
                                        <TextBlock Text="Scan to access the remote dashboard" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- Local Network (LAN) IP Card -->
                            <Border Grid.Row="1" Visibility="{Binding HasLocalUrl, Converter={StaticResource BoolToVis}}"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6" Padding="12,10" Margin="0,0,0,8"
                                    HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ui:SymbolIcon Grid.Row="0" Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" Symbol="Home24" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="Local Network (LAN)" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding LocalUrl}" FontSize="14" Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ui:Button Appearance="Secondary" Content="Copy URL" Icon="{ui:SymbolIcon Copy16}" Command="{Binding CopyLocalUrlCommand}"/>
                                        <ui:Button Appearance="Secondary" Content="QR Code" Icon="{ui:SymbolIcon QrCode24}" Command="{Binding ToggleLocalQrCommand}" Margin="8,0,0,0"/>
                                    </StackPanel>

                                    <!-- QR Code Area -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Visibility="{Binding IsLocalQrVisible, Converter={StaticResource BoolToVis}}" HorizontalAlignment="Center" Margin="0,12,0,4">
                                        <Border Background="White" Padding="8" CornerRadius="4" BorderThickness="1" BorderBrush="#E0E0E0" HorizontalAlignment="Center">
                                            <Image Source="{Binding LocalQrImage}" Width="150" Height="150" Stretch="Uniform"/>
                                        </Border>
                                        <TextBlock Text="Scan to access the local dashboard" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Status Text -->
                            <TextBlock Grid.Row="2" x:Name="RemoteStatusText" Text="{Binding StatusText}" FontSize="12" Margin="0,0,0,0" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#A6E3A1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                                <Setter Property="Foreground" Value="#F38BA8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon Shield24}" Margin="0,12,0,0" Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Security &amp; Authentication" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Require a password to access the remote dashboard." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Require password authentication" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="When enabled, anyone accessing the remote dashboard must enter the password."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleRequireAuthentication"
                                             Grid.Column="1"
                                             VerticalAlignment="Center"
                                             IsChecked="{Binding RequireAuthentication}"/>
                        </Grid>
                        
                        <Grid Margin="0,16,0,0" Visibility="{Binding RequireAuthentication, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Set Password" VerticalAlignment="Center" FontSize="14" FontWeight="Medium" Margin="0,0,12,0"/>
                            <ui:PasswordBox Grid.Row="0" Grid.Column="1" Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter new password (autosaves)" />
                            
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0" Visibility="{Binding IsPasswordSet, Converter={StaticResource BoolToVis}}">
                                <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="{DynamicResource SystemFillColorSuccessBrush}" Margin="0,0,6,0"/>
                                <TextBlock Text="Password is currently configured and saved." Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0" Visibility="{Binding IsPasswordNotSet, Converter={StaticResource BoolToVis}}">
                                <ui:SymbolIcon Symbol="Warning24" Foreground="{DynamicResource SystemFillColorCautionBrush}" Margin="0,0,6,0"/>
                                <TextBlock Text="No password configured! Dashboard may be vulnerable." Foreground="{DynamicResource SystemFillColorCautionBrush}" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon Shield24}" Margin="0,12,0,0" Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Remote Control Permissions" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Configure what actions paired devices are allowed to execute." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Allow remote console commands" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Remote console commands can fully control this Minecraft server. Only enable this for trusted paired devices."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleRemoteConsoleCommands"
                                             Grid.Column="1"
                                             VerticalAlignment="Center"
                                             IsChecked="{Binding AllowRemoteConsoleCommands}"/>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Allow remote player actions" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Allows paired devices to kick, ban, pardon, op, and de-op players from the remote dashboard."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleRemotePlayerActions"
                                             Grid.Column="1"
                                             VerticalAlignment="Center"
                                             IsChecked="{Binding AllowRemotePlayerActions}"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon Chat24}" Margin="0,12,0,0" Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Discord Notifications" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Link your Discord account to receive generated URLs via Direct Message." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Direct Message Notifications" FontSize="14" FontWeight="Medium"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="Status: " Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                    <TextBlock Text="Linked" Foreground="#A6E3A1" FontSize="12" Visibility="{Binding IsDiscordLinked, Converter={StaticResource BoolToVis}}"/>
                                    <TextBlock Text="Not Linked" Foreground="{DynamicResource TextFillColorDisabledBrush}" FontSize="12" Visibility="{Binding IsDiscordNotLinked, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                                
                                <StackPanel Margin="0,8,24,0" Visibility="{Binding IsDiscordNotLinked, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="To link your account, join our Discord server and use the /link command. You'll receive a connect button via DM."
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               FontSize="12" />
                                    <ui:Button Content="Join Discord Server" 
                                               Margin="0,12,0,0" 
                                               Appearance="Secondary"
                                               Icon="{ui:SymbolIcon Chat24}"
                                               Command="{Binding JoinDiscordCommand}" 
                                               HorizontalAlignment="Left" />
                                </StackPanel>

                                <TextBlock Text="Send an automatic Direct Message via your PocketMC Discord Bot when the remote control URL gets generated."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,8,24,0"
                                           Visibility="{Binding IsDiscordLinked, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleDiscordNotifications"
                                             Grid.Column="1"
                                             VerticalAlignment="Center"
                                             IsEnabled="{Binding IsDiscordLinked}"
                                             IsChecked="{Binding EnableDiscordNotifications}"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
