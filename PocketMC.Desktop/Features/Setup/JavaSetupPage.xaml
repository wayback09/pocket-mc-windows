<Page x:Class="PocketMC.Desktop.Features.Setup.JavaSetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Java Runtimes">

    <Grid Margin="36,24,36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ─── Header ─── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <ui:TextBlock FontTypography="Title" Text="Java Runtimes" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Managed JREs for your Minecraft server instances. Missing runtimes are downloaded automatically."
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap" FontSize="13" Margin="0,0,0,16"/>
        </StackPanel>

        <!-- ─── Action Bar ─── -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <ui:Button x:Name="BtnDownloadMissing"
                       Content="Download Missing"
                       Icon="{ui:SymbolIcon ArrowDownload24}"
                       Appearance="Primary"
                       Click="BtnDownloadMissing_Click"
                       Cursor="Hand" Margin="0,0,8,0"/>
            <ui:Button x:Name="BtnAddCustom"
                       Content="Add Custom Runtime"
                       Icon="{ui:SymbolIcon FolderAdd24}"
                       Click="BtnAddCustom_Click"
                       Cursor="Hand" Margin="0,0,8,0"/>
            <ui:Button x:Name="BtnRefresh"
                       Content="Refresh"
                       Icon="{ui:SymbolIcon ArrowSync24}"
                       Click="BtnRefresh_Click"
                       Cursor="Hand"/>
        </StackPanel>

        <!-- ─── Runtime Cards ─── -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="RuntimeList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16,14"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Version tile -->
                                <Border Grid.Column="0" Width="42" Height="42"
                                        CornerRadius="10" Margin="0,0,14,0"
                                        VerticalAlignment="Center"
                                        Background="{Binding StatusBackground}">
                                    <TextBlock Text="{Binding VersionLabel}"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Info column -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <!-- Status badge -->
                                        <Border Background="{Binding BadgeBackground}"
                                                CornerRadius="4" Padding="7,2"
                                                Margin="10,0,0,0" VerticalAlignment="Center"
                                                Visibility="{Binding BadgeVisibility}">
                                            <TextBlock Text="{Binding BadgeText}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{Binding BadgeForeground}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding DetailText}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               MaxWidth="560"
                                               HorizontalAlignment="Left"
                                               Margin="0,3,0,0"/>
                                    <!-- Download progress -->
                                    <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="100"
                                                 Height="3" Margin="0,6,0,0"
                                                 Visibility="{Binding ProgressVisibility}"/>
                                </StackPanel>

                                <!-- Status glyph (Segoe Fluent Icons) -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding StatusIcon}"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="{Binding StatusIconForeground}"
                                           VerticalAlignment="Center"
                                           Margin="12,0"/>

                                <!-- Delete button (subtle, icon-only) -->
                                <ui:Button Grid.Column="3"
                                           Icon="{ui:SymbolIcon Delete24}"
                                           Appearance="Secondary"
                                           ToolTip="Delete this runtime"
                                           Click="BtnDelete_Click"
                                           Tag="{Binding}"
                                           Visibility="{Binding DeleteVisibility}"
                                           VerticalAlignment="Center"
                                           Cursor="Hand" Margin="0,0,8,0"/>

                                <!-- Download button (subtle, icon-only) -->
                                <ui:Button Grid.Column="4"
                                           Icon="{ui:SymbolIcon ArrowDownload24}"
                                           Appearance="Primary"
                                           ToolTip="Download this runtime"
                                           Click="BtnDownloadSingle_Click"
                                           Tag="{Binding}"
                                           Visibility="{Binding DownloadVisibility}"
                                           VerticalAlignment="Center"
                                           Cursor="Hand"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ─── Status Bar ─── -->
        <TextBlock x:Name="TxtGlobalStatus" Grid.Row="3"
                   Text=""
                   HorizontalAlignment="Left"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                   Margin="0,12,0,0"/>
    </Grid>
</Page>
