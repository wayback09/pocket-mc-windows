<ui:FluentWindow x:Class="PocketMC.Desktop.Features.Marketplace.DependencyConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:PocketMC.Desktop.Features.Marketplace"
        xmlns:models="clr-namespace:PocketMC.Desktop.Features.Marketplace.Models"
        xmlns:pres="clr-namespace:PocketMC.Desktop.Core.Presentation"
        mc:Ignorable="d"
        Title="Confirm Installation" Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <local:DependencyTypeToAppearanceConverter x:Key="DependencyTypeToAppearanceConverter"/>
        <pres:NullOrEmptyToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <pres:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </ui:FluentWindow.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,10,0,10">
            <TextBlock Text="Ready to Install" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="The following items will be installed on your server." Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource SystemFillColorCautionBackgroundBrush}" 
                Visibility="{Binding HasErrors, Converter={StaticResource BooleanToVisibilityConverter}}"
                Padding="10" CornerRadius="4" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Warning24" Margin="0,0,10,0" Foreground="{DynamicResource SystemFillColorCautionBrush}"/>
                <TextBlock Text="Some dependencies could not be resolved or have issues." VerticalAlignment="Center" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <ListView Grid.Row="2" ItemsSource="{Binding Dependencies}" 
                  BorderThickness="0" Background="Transparent"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  SelectionMode="Single"
                  IsHitTestVisible="True">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="IsTabStop" Value="False"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox IsChecked="{Binding IsSelected}" 
                                  IsEnabled="{Binding IsCheckboxEnabled}"
                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                  VerticalAlignment="Center" Margin="0,0,10,0"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,4">
                            <TextBlock Text="{Binding ProjectTitle}" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Visibility="{Binding DownloadUrl, Converter={StaticResource StringToVisibilityConverter}}">
                                <Run Text="{Binding VersionName}"/>
                                <Run Text=" | "/>
                                <Run Text="{Binding FileName}"/>
                                <Run Text=" | "/>
                                <Run Text="{Binding Provider}"/>
                            </TextBlock>

                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0" Visibility="{Binding SelectedLoader, Converter={StaticResource StringToVisibilityConverter}}">
                                <TextBlock Text="Loader: " FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                <TextBlock Text="{Binding SelectedLoader}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="Game Version: " FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                <TextBlock Text="{Binding MatchedMinecraftVersion}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <TextBlock Text="{Binding Warning}" FontSize="12" Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                       Visibility="{Binding Warning, Converter={StaticResource StringToVisibilityConverter}}"/>
                            
                            <TextBlock Text="{Binding Error}" FontSize="12" Foreground="{DynamicResource SystemFillColorCriticalBrush}" 
                                       Visibility="{Binding Error, Converter={StaticResource StringToVisibilityConverter}}"
                                       TextWrapping="Wrap" FontWeight="SemiBold"/>

                            <Border Margin="0,4,0,0" Padding="8" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Visibility="{Binding Error, Converter={StaticResource StringToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Technical Details" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Project ID:" Grid.Row="0" Grid.Column="0" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,8,2"/>
                                        <TextBlock Text="{Binding ProjectId}" Grid.Row="0" Grid.Column="1" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,2"/>
                                        
                                        <TextBlock Text="Version ID:" Grid.Row="1" Grid.Column="0" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,8,2"
                                                   Visibility="{Binding VersionId, Converter={StaticResource StringToVisibilityConverter}}"/>
                                        <TextBlock Text="{Binding VersionId}" Grid.Row="1" Grid.Column="1" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,2"
                                                   Visibility="{Binding VersionId, Converter={StaticResource StringToVisibilityConverter}}"/>

                                        <TextBlock Text="Provider:" Grid.Row="2" Grid.Column="0" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,8,2"/>
                                        <TextBlock Text="{Binding Provider}" Grid.Row="2" Grid.Column="1" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,2"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0" Orientation="Horizontal">
                            <Border CornerRadius="4" Padding="10,4" Background="{DynamicResource SystemFillColorNeutralBrush}" 
                                    Visibility="{Binding IsAlreadyInstalled, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Margin="0,0,6,0">
                                <TextBlock Text="Already Installed" Foreground="{DynamicResource SystemControlForegroundAltHighBrush}" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                            <Border CornerRadius="4" Padding="10,4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorNeutralBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static models:DependencyType.Required}">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static models:DependencyType.Incompatible}">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static models:DependencyType.Embedded}">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Type}" Foreground="{DynamicResource SystemControlForegroundAltHighBrush}" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <ui:Button Content="Cancel" Command="{Binding CancelCommand}" Width="100" Margin="0,0,10,0" IsCancel="True"/>
            <ui:Button Content="Install" Appearance="Primary" Command="{Binding ConfirmCommand}" Width="120"
                       IsEnabled="{Binding CanInstall}" IsDefault="True"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
