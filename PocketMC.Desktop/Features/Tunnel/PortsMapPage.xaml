<Page x:Class="PocketMC.Desktop.Features.Tunnel.PortsMapPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:presentation="clr-namespace:PocketMC.Desktop.Core.Presentation"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="950"
      Title="Ports Map"
      Background="Transparent">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="VisibleIfTrue"/>
        <presentation:InverseBooleanToVisibilityConverter x:Key="VisibleIfFalse"/>

        <Style TargetType="TextBlock" x:Key="NodeSubtitle">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
        </Style>
    </Page.Resources>

    <Grid Margin="36,20,36,24" VerticalAlignment="Stretch">
        <DockPanel LastChildFill="True">

            <!-- Title & Navigation Row -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:Button Icon="{ui:SymbolIcon ArrowLeft24}"
                               Appearance="Transparent"
                               Click="BtnBack_Click"
                               Margin="0,0,12,0"
                               Padding="6"
                               ToolTip="Back to Tunnels"/>
                    <ui:TextBlock FontTypography="Title"
                                  Text="Interactive Ports Map"
                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                  VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="An interactive topology map visualizing how public internet traffic routes through Playit.gg tunnels to your local server ports. Grouped by server instance."
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="13"
                           Margin="48,0,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Bottom Diagnostic Info Bar -->
            <Border DockPanel.Dock="Bottom"
                    Margin="0,16,0,0"
                    Padding="16,14"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Info24" Foreground="{DynamicResource SystemFillColorAttentionBrush}" Margin="0,0,10,0"/>
                        <TextBlock Text="Tip: Running servers are expanded automatically. Click 'View Console / Manage' on a server to interact with it directly."
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <ui:Button Content="Refresh Map" Click="BtnRefresh_Click" Appearance="Secondary" Icon="{ui:SymbolIcon ArrowSync24}" HorizontalAlignment="Right" Padding="10,5"/>
                </Grid>
            </Border>

            <!-- Main Route Topology Area -->
            <Grid>
                <!-- Loading State -->
                <Grid x:Name="LoadingOverlay" Visibility="Collapsed" Panel.ZIndex="10" Background="#90000000">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ui:ProgressRing IsIndeterminate="True" Width="40" Height="40" Margin="0,0,0,16"/>
                        <TextBlock Text="Mapping active network interfaces..." Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>

                <!-- No Tunnels/Offline message -->
                <StackPanel x:Name="NoRoutesPanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,50,0,0">
                    <ui:SymbolIcon Symbol="Globe24" FontSize="48" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                    <TextBlock Text="No active network routes discovered" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Start a Minecraft server instance or connect your Playit.gg agent to see routes charted here." TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13" TextAlignment="Center" MaxWidth="400"/>
                </StackPanel>

                <!-- Active Map Scroll -->
                <ScrollViewer x:Name="PortsMapScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              PanningMode="VerticalOnly"
                              Padding="0,0,12,0">
                    <ItemsControl x:Name="RoutesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:CardExpander Margin="0,0,0,16" Padding="16,12" IsExpanded="{Binding IsExpanded}" HorizontalContentAlignment="Stretch">
                                    <ui:CardExpander.Header>
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <!-- Status glow icon -->
                                                <ColumnDefinition Width="Auto"/>
                                                <!-- Server details -->
                                                <ColumnDefinition Width="*"/>
                                                <!-- Action controls -->
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Status glow icon -->
                                            <Grid Grid.Column="0" Width="36" Height="36" VerticalAlignment="Center">
                                                <Border CornerRadius="18" Background="{Binding ActiveColor}" Opacity="0.15"/>
                                                <ui:SymbolIcon Symbol="Server24" FontSize="18" Foreground="{Binding ActiveColor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>

                                            <!-- Server Metadata -->
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ServerName}" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Text="{Binding ServerInfo}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Action controls & metrics -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,36,0">
                                                <TextBlock Text="{Binding PlayerMetrics}" FontSize="12" FontWeight="SemiBold" Foreground="{Binding ActiveColor}" VerticalAlignment="Center" Margin="0,0,16,0" Visibility="{Binding PlayerMetricsVisibility}"/>
                                                <ui:Button Content="{Binding ActionButtonText}" 
                                                           Icon="{Binding ActionButtonIcon}"
                                                           Appearance="Secondary"
                                                           Command="{Binding DataContext.NavigateToConsoleCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding ServerId}"
                                                           Padding="12,6"
                                                           Cursor="Hand"/>
                                            </StackPanel>
                                        </Grid>
                                    </ui:CardExpander.Header>

                                    <!-- EXPANDER BODY: Inner List of Network Routes -->
                                    <ItemsControl ItemsSource="{Binding Routes}" Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10" Padding="14,12" Margin="0,0,0,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <!-- Column 1: Public Domain -->
                                                            <ColumnDefinition Width="250"/>
                                                            <!-- Column 2: Connector Path -->
                                                            <ColumnDefinition Width="*"/>
                                                            <!-- Column 3: Local Port Binding -->
                                                            <ColumnDefinition Width="170"/>
                                                            <!-- Column 4: Connector Path -->
                                                            <ColumnDefinition Width="*"/>
                                                            <!-- Column 5: Target Service Role -->
                                                            <ColumnDefinition Width="230"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- NODE 1: PUBLIC PLAYIT ENDPOINT -->
                                                        <Border Grid.Column="0" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10" VerticalAlignment="Center">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding PublicAddressLabel}" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" ToolTip="{Binding PublicAddress}"/>
                                                                    <TextBlock Text="{Binding ProtocolLabel}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                                                    <TextBlock Text="Playit.gg Public Entry" FontSize="9" Foreground="{DynamicResource SystemFillColorAttentionBrush}" Margin="0,4,0,0"/>
                                                                </StackPanel>
                                                                <ui:Button Grid.Column="1" ToolTip="Copy Address" Appearance="Transparent" Icon="{ui:SymbolIcon Copy24}" Padding="6" Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding PublicAddress}" VerticalAlignment="Center" Cursor="Hand" Visibility="{Binding HasTunnel, Converter={StaticResource VisibleIfTrue}}"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- CONNECTOR 1: INTERNET TO LOCAL -->
                                                        <Grid Grid.Column="1" Height="20" VerticalAlignment="Center">
                                                            <!-- Inactive line -->
                                                            <Line X1="0" Y1="10" X2="200" Y2="10" StrokeThickness="2" Stroke="#444" StrokeDashArray="3,3" Stretch="Fill"/>
                                                            <!-- Active animated neon line -->
                                                            <Line X1="0" Y1="10" X2="200" Y2="10" StrokeThickness="2" Stroke="{Binding ActiveColor}" Stretch="Fill" Visibility="{Binding IsOnline, Converter={StaticResource VisibleIfTrue}}"/>
                                                            <ui:SymbolIcon Symbol="ArrowRight16" Foreground="{Binding ActiveColor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Grid>

                                                         <!-- NODE 2: LOCAL PORT ALLOCATION -->
                                                         <Border Grid.Column="2" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="8,10" VerticalAlignment="Center">
                                                             <Grid>
                                                                 <!-- State 1: Normal Display Mode -->
                                                                 <Grid Visibility="{Binding IsEditingPort, Converter={StaticResource VisibleIfFalse}}">
                                                                     <Grid.ColumnDefinitions>
                                                                         <ColumnDefinition Width="*"/>
                                                                         <ColumnDefinition Width="Auto"/>
                                                                     </Grid.ColumnDefinitions>
                                                                     <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                         <TextBlock Text="{Binding LocalPortLabel}" FontWeight="Bold" FontSize="14" Foreground="{Binding ActiveColor}" HorizontalAlignment="Center"/>
                                                                         <TextBlock Text="Local Loopback (IP)" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                                         <TextBlock Text="Reserved &amp; Probed" FontSize="8" Foreground="{DynamicResource SystemFillColorSuccessBrush}" HorizontalAlignment="Center" Margin="0,4,0,0" Visibility="{Binding IsLeased, Converter={StaticResource VisibleIfTrue}}"/>
                                                                     </StackPanel>
                                                                     <ui:Button Grid.Column="1" 
                                                                                Icon="{ui:SymbolIcon Edit20}"
                                                                                Appearance="Transparent"
                                                                                Padding="4"
                                                                                Margin="4,0,0,0"
                                                                                VerticalAlignment="Center"
                                                                                Command="{Binding DataContext.EditPortCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                                CommandParameter="{Binding}"
                                                                                ToolTip="Edit Port"
                                                                                Cursor="Hand"/>
                                                                 </Grid>

                                                                 <!-- State 2: Edit Inline Mode -->
                                                                 <Grid Visibility="{Binding IsEditingPort, Converter={StaticResource VisibleIfTrue}}">
                                                                     <Grid.ColumnDefinitions>
                                                                         <ColumnDefinition Width="*"/>
                                                                         <ColumnDefinition Width="Auto"/>
                                                                         <ColumnDefinition Width="Auto"/>
                                                                     </Grid.ColumnDefinitions>
                                                                     <ui:TextBox Grid.Column="0" 
                                                                                 Text="{Binding EditingPortText, UpdateSourceTrigger=PropertyChanged}"
                                                                                 PlaceholderText="Port"
                                                                                 FontSize="12"
                                                                                 FontWeight="Bold"
                                                                                 Padding="4,2"
                                                                                 Height="28"
                                                                                 Width="68"
                                                                                 VerticalAlignment="Center"
                                                                                 HorizontalContentAlignment="Center"
                                                                                 KeyDown="TxtPort_KeyDown"/>
                                                                     <ui:Button Grid.Column="1" 
                                                                                Icon="{ui:SymbolIcon Checkmark20}"
                                                                                Appearance="Transparent"
                                                                                Padding="4"
                                                                                Margin="4,0,0,0"
                                                                                VerticalAlignment="Center"
                                                                                Command="{Binding DataContext.SavePortCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                                CommandParameter="{Binding}"
                                                                                ToolTip="Save Port"
                                                                                Cursor="Hand"/>
                                                                     <ui:Button Grid.Column="2" 
                                                                                Icon="{ui:SymbolIcon Dismiss20}"
                                                                                Appearance="Transparent"
                                                                                Padding="4"
                                                                                Margin="2,0,0,0"
                                                                                VerticalAlignment="Center"
                                                                                Command="{Binding DataContext.CancelPortCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                                CommandParameter="{Binding}"
                                                                                ToolTip="Cancel"
                                                                                Cursor="Hand"/>
                                                                 </Grid>
                                                             </Grid>
                                                         </Border>

                                                        <!-- CONNECTOR 2: LOCAL TO INSTANCE -->
                                                        <Grid Grid.Column="3" Height="20" VerticalAlignment="Center">
                                                            <Line X1="0" Y1="10" X2="200" Y2="10" StrokeThickness="2" Stroke="#444" StrokeDashArray="3,3" Stretch="Fill"/>
                                                            <Line X1="0" Y1="10" X2="200" Y2="10" StrokeThickness="2" Stroke="{Binding ActiveColor}" Stretch="Fill" Visibility="{Binding IsOnline, Converter={StaticResource VisibleIfTrue}}"/>
                                                            <ui:SymbolIcon Symbol="ArrowRight16" Foreground="{Binding ActiveColor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Grid>

                                                        <!-- NODE 3: TARGET SERVICE ROLE -->
                                                        <Border Grid.Column="4" BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" CornerRadius="8" Padding="12,10" VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                            <Setter Property="Background" Value="#1000FF00"/>
                                                                            <Setter Property="BorderBrush" Value="#8000FF00"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="8"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>

                                                                <Grid Grid.Column="0" Width="30" Height="30" VerticalAlignment="Center">
                                                                    <Border CornerRadius="15" Background="{Binding ActiveColor}" Opacity="0.15"/>
                                                                    <ui:SymbolIcon Symbol="Link24" FontSize="14" Foreground="{Binding ActiveColor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Grid>

                                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding ServiceRoleName}" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Text="{Binding ServiceRoleDetail}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ui:CardExpander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

        </DockPanel>
    </Grid>
</Page>
