<ui:FluentWindow x:Class="PocketMC.Desktop.Infrastructure.AppDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{Binding ElementName=TxtTitle, Path=Text}"
        Width="420"
        SizeToContent="Height"
        MinWidth="360" MaxWidth="520"
        MinHeight="0"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowCornerPreference="Round"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="None"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="20" MaxWidth="480">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: icon + title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock x:Name="TxtIcon"
                       FontSize="18"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <TextBlock x:Name="TxtTitle"
                       FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- Message body -->
        <ScrollViewer Grid.Row="1"
                      MaxHeight="260"
                      VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="TxtMessage"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       LineHeight="20"/>
        </ScrollViewer>

        <!-- Action buttons -->
        <WrapPanel Grid.Row="2" HorizontalAlignment="Right" Margin="0,18,0,0">
            <ui:Button x:Name="BtnTertiary"
                       MinWidth="80"
                       Margin="0,0,8,0"
                       Visibility="Collapsed"
                       Click="BtnTertiary_Click"/>

            <ui:Button x:Name="BtnSecondary"
                       MinWidth="80"
                       Margin="0,0,8,0"
                       Visibility="Collapsed"
                       Click="BtnSecondary_Click"/>

            <ui:Button x:Name="BtnPrimary"
                       Content="OK"
                       Appearance="Primary"
                       MinWidth="90"
                       Click="BtnPrimary_Click"
                       IsDefault="True"/>
        </WrapPanel>

    </Grid>
</ui:FluentWindow>
