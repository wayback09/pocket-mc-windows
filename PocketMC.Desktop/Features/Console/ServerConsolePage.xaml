<Page x:Class="PocketMC.Desktop.Features.Console.ServerConsolePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:markdig="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
      xmlns:infra="clr-namespace:PocketMC.Desktop.Infrastructure"
      Title="Server Console"
      PreviewKeyDown="Page_PreviewKeyDown">

    <Grid x:Name="PageRoot" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top bar: Console actions -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0" Content="Back" Appearance="Secondary"
                       Icon="{ui:SymbolIcon ArrowLeft24}" Click="BtnBack_Click" Cursor="Hand" Margin="0,0,12,0"/>

            <ToggleButton x:Name="BtnAutoScroll" Grid.Column="1" Content="Auto-scroll"
                          IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0" Cursor="Hand" Padding="12,5"/>

            <ui:Button Grid.Column="2" Content="Copy Logs" Appearance="Secondary"
                       Icon="{ui:SymbolIcon Copy24}" Click="BtnCopyLogs_Click" Cursor="Hand" Margin="0,0,8,0"/>

            <ui:TextBox x:Name="TxtLogSearch" Grid.Column="3" PlaceholderText="Search logs..."
                        Margin="0,0,4,0" MinWidth="160" VerticalAlignment="Center"
                        TextChanged="TxtLogSearch_TextChanged"/>

            <ToggleButton Grid.Column="4" Content=".*" ToolTip="Use Regex"
                          IsChecked="{Binding IsRegexEnabled}"
                          VerticalAlignment="Center" Margin="0,0,12,0"
                          Width="32" Height="32" Padding="0" Cursor="Hand"/>

            <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                <ToggleButton Content="Chat" IsChecked="{Binding IsFilterChat}" Margin="0,0,4,0" Padding="8,4" Cursor="Hand"/>
                <ToggleButton Content="Info" IsChecked="{Binding IsFilterInfo}" Margin="0,0,4,0" Padding="8,4" Cursor="Hand"/>
                <ToggleButton Content="Warn" IsChecked="{Binding IsFilterWarn}" Margin="0,0,4,0" Padding="8,4" Cursor="Hand"/>
                <ToggleButton Content="Error" IsChecked="{Binding IsFilterError}" Margin="0,0,4,0" Padding="8,4" Cursor="Hand"/>
                <ToggleButton Content="Sys" IsChecked="{Binding IsFilterSystem}" Padding="8,4" Cursor="Hand"/>
            </StackPanel>

            <ui:Button Grid.Column="6" Content="{Binding PlayerStatus}" Appearance="Secondary"
                       Icon="{ui:SymbolIcon People24}" Click="BtnPlayers_Click" Cursor="Hand" Margin="0,0,8,0"
                       ToolTip="Manage online players"/>

            <ui:Button Grid.Column="7" Content="Stop Server" Appearance="Danger"
                       Icon="{ui:SymbolIcon Stop24}" Click="BtnStop_Click" Cursor="Hand" Margin="0,0,8,0"
                       IsEnabled="{Binding CanStopServer}"/>

            <ui:Button Grid.Column="8" Content="Restart" Appearance="Secondary"
                       Icon="{ui:SymbolIcon ArrowSync24}" Click="BtnRestart_Click" Cursor="Hand" Margin="0,0,8,0"/>

            <ui:Button Grid.Column="9" Content="AI Summary" Appearance="Info"
                       Icon="{ui:SymbolIcon Sparkle24}" Click="BtnAiSummary_Click" Cursor="Hand"
                       ToolTip="Generate AI session summary"/>
        </Grid>

        <!-- Console output area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="AiPanelColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="8" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ui:InfoBar Grid.Row="0" x:Name="ResourceWarningBar"
                             Title="High Resource Usage"
                             Message="Your server is using over 80% of its assigned RAM. Performance may be impacted."
                             Severity="Warning" Margin="0,0,0,10"
                             IsClosable="False"
                             Visibility="Collapsed">
                    <ui:Button Content="Optimize" Appearance="Primary" Click="BtnOptimize_Click"
                               Margin="0,0,12,0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </ui:InfoBar>

                <Border Grid.Row="1" x:Name="CrashBanner" Background="#EE1A1A1A" BorderBrush="#FF4444" BorderThickness="1,1,1,2" CornerRadius="8" Padding="0" Margin="0,0,0,12" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header with Actions -->
                        <Border Grid.Row="0" Background="#33FF4444" CornerRadius="7,7,0,0" Padding="12,8">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Warning24" Margin="0,0,8,0" Foreground="#FF6B6B"/>
                                    <ui:TextBlock FontTypography="Subtitle" Text="Critical Crash Detected!" Foreground="#FF6B6B" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <ui:Button Content="Copy Report" Appearance="Secondary" Icon="{ui:SymbolIcon Copy24}" Margin="0,0,8,0" Padding="8,4" Click="BtnCopyCrash_Click"/>
                                    <ui:Button Appearance="Transparent" Icon="{ui:SymbolIcon Dismiss24}" Padding="4" Click="BtnDismissCrash_Click" ToolTip="Hide Banner"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" MaxHeight="150" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="12">
                            <TextBlock x:Name="TxtCrashLog" Foreground="#FF6B6B" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Opacity="0.9"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Virtualized Log View -->
                <ListView x:Name="LogView" Grid.Row="2" ItemsSource="{Binding FilteredLogs}"
                            Background="Transparent" BorderThickness="0"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            VirtualizingStackPanel.IsVirtualizing="True"
                            VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid x:Name="LogItemGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Text}" Foreground="{Binding TextColor}"
                                           FontFamily="Consolas" FontSize="13" TextWrapping="Wrap"
                                           Padding="4,1"/>

                                <ui:Button x:Name="BtnAnalyze" Grid.Column="1"
                                           Icon="{ui:SymbolIcon Sparkle16}"
                                           Appearance="Transparent" Padding="4,2" Margin="4,0"
                                           VerticalAlignment="Top" Cursor="Hand"
                                           ToolTip="AI: Explain this error"
                                           Click="BtnAnalyzeLine_Click"
                                           Visibility="Collapsed"/>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                    <Setter TargetName="BtnAnalyze" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Level}" Value="Warn">
                                    <Setter TargetName="BtnAnalyze" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Border>
            <!-- AI Side Panel Content -->
            <Border Grid.Column="1" Background="#252525" Margin="8,0,0,0" CornerRadius="8" BorderBrush="#333" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#2D2D2D" CornerRadius="8,8,0,0" Padding="12,8">
                        <Grid>
                            <ui:TextBlock Text="AI Intelligence" FontTypography="Caption" Foreground="White" VerticalAlignment="Center"/>
                            <ui:Button Appearance="Transparent" Icon="{ui:SymbolIcon Dismiss24}"
                                       HorizontalAlignment="Right" Click="BtnCloseAiPanel_Click" Padding="4"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="10,8" x:Name="AiResultScroller"
                                  Background="Transparent"
                                  VerticalScrollBarVisibility="Auto">                        <StackPanel Background="Transparent">
                            <ui:TextBlock x:Name="TxtAiStatus" Text="Ready to analyze..." Foreground="#888"
                                           FontStyle="Italic" Margin="0,0,0,16" Visibility="Collapsed"/>
                            <ui:ProgressRing x:Name="AiProgress" IsIndeterminate="True" Height="28" Width="28"
                                              HorizontalAlignment="Center" Margin="0,30" Visibility="Collapsed"/>

                            <markdig:MarkdownViewer x:Name="TxtAiResponse"
                                                    Background="Transparent"
                                                    Foreground="#D1D5DB"
                                                    Margin="0"
                                                    Padding="0"
                                                    Pipeline="{x:Static infra:MarkdownConfig.Pipeline}">
                                <markdig:MarkdownViewer.Resources>
                                    <!-- === AI Panel Markdown Styles (optimized for 420px panel) === -->

                                    <!-- Base Document: LEFT-ALIGN to prevent ugly word spacing -->
                                    <Style x:Key="{x:Static markdig:Styles.DocumentStyleKey}" TargetType="{x:Type FlowDocument}">
                                        <Setter Property="Foreground" Value="#D1D5DB" />
                                        <Setter Property="FontFamily" Value="Segoe UI, Inter, Roboto" />
                                        <Setter Property="TextAlignment" Value="Left" />
                                    </Style>

                                    <!-- Paragraphs -->
                                    <Style TargetType="{x:Type Paragraph}">
                                        <Setter Property="Margin" Value="0,0,0,8" />
                                        <Setter Property="LineHeight" Value="18" />
                                        <Setter Property="FontSize" Value="12" />
                                        <Setter Property="Foreground" Value="#D1D5DB" />
                                        <Setter Property="TextAlignment" Value="Left" />
                                    </Style>

                                    <!-- Headings: WHITE for visibility on dark bg -->
                                    <Style x:Key="{x:Static markdig:Styles.Heading1StyleKey}" TargetType="{x:Type Paragraph}">
                                        <Setter Property="Foreground" Value="#F9FAFB" />
                                        <Setter Property="FontSize" Value="15" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Setter Property="Margin" Value="0,10,0,8" />
                                        <Setter Property="TextAlignment" Value="Left" />
                                    </Style>

                                    <Style x:Key="{x:Static markdig:Styles.Heading2StyleKey}" TargetType="{x:Type Paragraph}">
                                        <Setter Property="Foreground" Value="#F3F4F6" />
                                        <Setter Property="FontSize" Value="13.5" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Margin" Value="0,12,0,6" />
                                        <Setter Property="TextAlignment" Value="Left" />
                                    </Style>

                                    <Style x:Key="{x:Static markdig:Styles.Heading3StyleKey}" TargetType="{x:Type Paragraph}">
                                        <Setter Property="Foreground" Value="#E5E7EB" />
                                        <Setter Property="FontSize" Value="12.5" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Margin" Value="0,10,0,4" />
                                        <Setter Property="TextAlignment" Value="Left" />
                                    </Style>

                                    <Style x:Key="{x:Static markdig:Styles.Heading4StyleKey}" TargetType="{x:Type Paragraph}">
                                        <Setter Property="Foreground" Value="#E5E7EB" />
                                        <Setter Property="FontSize" Value="12" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Margin" Value="0,8,0,4" />
                                        <Setter Property="TextAlignment" Value="Left" />
                                    </Style>

                                    <!-- Lists: minimal indentation for narrow panel -->
                                    <Style TargetType="{x:Type List}">
                                        <Setter Property="Margin" Value="6,0,0,6" />
                                        <Setter Property="Padding" Value="0" />
                                    </Style>

                                    <Style TargetType="{x:Type ListItem}">
                                        <Setter Property="Margin" Value="0,0,0,3" />
                                    </Style>

                                    <!-- Bullet dots -->
                                    <Style TargetType="{x:Type Ellipse}">
                                        <Setter Property="Fill" Value="#34D399" />
                                        <Setter Property="Width" Value="4" />
                                        <Setter Property="Height" Value="4" />
                                        <Setter Property="Opacity" Value="0.7" />
                                    </Style>

                                    <!-- Inline code -->
                                    <Style x:Key="{x:Static markdig:Styles.CodeStyleKey}" TargetType="{x:Type Run}">
                                        <Setter Property="FontFamily" Value="Consolas" />
                                        <Setter Property="Foreground" Value="#34D399" />
                                        <Setter Property="Background" Value="#1A1A1A" />
                                        <Setter Property="FontSize" Value="11" />
                                    </Style>

                                    <!-- Code blocks -->
                                    <Style x:Key="{x:Static markdig:Styles.CodeBlockStyleKey}" TargetType="{x:Type Paragraph}">
                                        <Setter Property="Background" Value="#0D0D0D" />
                                        <Setter Property="Foreground" Value="#A7F3D0" />
                                        <Setter Property="FontFamily" Value="Consolas" />
                                        <Setter Property="Padding" Value="8" />
                                        <Setter Property="Margin" Value="0,4,0,10" />
                                        <Setter Property="FontSize" Value="11" />
                                        <Setter Property="TextAlignment" Value="Left" />
                                    </Style>

                                    <!-- Bold inherits parent color -->
                                    <Style TargetType="{x:Type Bold}">
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </Style>

                                    <!-- Hyperlinks -->
                                    <Style TargetType="{x:Type Hyperlink}">
                                        <Setter Property="Foreground" Value="#10B981" />
                                        <Setter Property="TextDecorations" Value="None" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="TextDecorations" Value="Underline" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </markdig:MarkdownViewer.Resources>

                                <markdig:MarkdownViewer.Style>
                                    <Style TargetType="markdig:MarkdownViewer">
                                        <Style.Triggers>
                                            <Trigger Property="Markdown" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </Trigger>
                                            <Trigger Property="Markdown" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </markdig:MarkdownViewer.Style>
                            </markdig:MarkdownViewer>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#2D2D2D" CornerRadius="0,0,8,8" Padding="12,8">
                        <ui:TextBlock Text="Powered by PocketMC Intelligence" FontTypography="Caption"
                                       Foreground="#666" HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:TextBox x:Name="TxtCommand" Grid.Column="0" PlaceholderText="Type a command..."
                        Margin="0,0,8,0"
                        KeyDown="TxtCommand_KeyDown"/>
            <ui:Button Grid.Column="1" Content="Send" Appearance="Primary"
                       Icon="{ui:SymbolIcon Send24}" Click="BtnSend_Click" Cursor="Hand"/>
        </Grid>
    </Grid>
</Page>
